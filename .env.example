# -------- Domaines --------
DOMAIN=crm.mdoservices.fr
ACME_EMAIL=mathieu@mdoservices.fr

# -------- Branding (multi-instance / revente DSI) --------
# Tous ces champs ont un defaut "MDO Services" si non definis. Utilises pour
# brander chaque instance client : nom affiche dans les emails, logo, footer
# du portail, titre du login, manifest PWA, etc.
# Pour une instance MDO classique : laisser les defauts ou commenter.
# Pour un client DSI revente : surcharger avec leur identite.
BRAND_NAME="MDO Services"
BRAND_SHORT_NAME="MDO"
BRAND_TAGLINE="Prestataire IT et Cybersecurite - Occitanie"
BRAND_SUPPORT_EMAIL=support@mdoservices.fr
BRAND_DPO_EMAIL=dpo@mdoservices.fr
BRAND_WEBSITE_URL=https://www.mdoservices.fr
# URL du logo (PNG/SVG hostes ou chemin relatif /logo.svg place dans frontend/public)
BRAND_LOGO_URL=/logo.svg
# Couleur primaire en HEX (utilisee pour le splash mobile + accents UI optionnels)
BRAND_PRIMARY_COLOR=#1d4ed8
# Texte du footer affichage portail
BRAND_FOOTER_TEXT="MDO Services - Prestataire IT et Cybersecurite - Occitanie"
# Type d'instance : MDO (instance interne) ou CLIENT (instance revendue a un DSI client)
# Affecte certaines metadata d'audit / identification
BRAND_INSTANCE_TYPE=MDO

# -------- PostgreSQL --------
POSTGRES_DB=crm_mdo
POSTGRES_USER=crm_mdo
POSTGRES_PASSWORD=change_me_strong_password
DATABASE_URL=postgresql://crm_mdo:change_me_strong_password@postgres:5432/crm_mdo?schema=public

# -------- Redis --------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me_redis_password

# -------- Backend --------
NODE_ENV=production
BACKEND_PORT=4000
JWT_SECRET=change_me_to_a_random_64_char_hex_string
JWT_REFRESH_SECRET=change_me_another_random_64_char_hex_string
# Cle maitre pour chiffrer les secrets clients (coffre-fort) et secrets 2FA TOTP
# IMPORTANT : ne JAMAIS la changer apres mise en service, sinon les secrets stockes sont perdus
SECRETS_MASTER_KEY=change_me_random_64_char_hex_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
CORS_ORIGIN=https://crm.mdoservices.fr

# Alertes renouvellement contrat (jours avant expiration)
CONTRACT_ALERT_DAYS=90,60,30,7

# Schema sync : si "true", le backend bootera avec `prisma db push` quand aucune
# migration n'est presente (bypass tracabilite). A laisser "true" UNIQUEMENT
# pendant la transition vers les migrations versionnees (cf docs/prisma-migrations.md),
# puis passer a "false" en prod multi-instance.
ALLOW_PRISMA_DB_PUSH_FALLBACK=false

# -------- Frontend --------
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=https://crm.mdoservices.fr/api

# -------- SMTP (emails transactionnels sortants) --------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=no-reply@mdoservices.fr
SMTP_PASSWORD=change_me
SMTP_FROM="CRM MDO Services <no-reply@mdoservices.fr>"
SMTP_SECURE=false

# -------- IMAP entrant (creation de tickets depuis support@mdoservices.fr) --------
# Mettre INBOUND_EMAIL_ENABLED=true pour activer le polling toutes les 2 min
INBOUND_EMAIL_ENABLED=false
# Envoi auto d'un accuse de reception au client lors de la creation d'un ticket
INBOUND_AUTO_ACK=true
# Taille max d'une piece jointe (en Mo)
MAX_UPLOAD_SIZE_MB=25

# -------- Lookup annuaire entreprises --------
# La recherche fonctionne par defaut GRATUITEMENT et sans cle via l'API gouv
# "Recherche d'entreprises" (recherche-entreprises.api.gouv.fr).
# INSEE Sirene : OPTIONNEL (fallback, donnees plus brutes).
#   Inscription : https://api.insee.fr  (cle d'integration X-INSEE-Api-Key-Integration)
SIRENE_API_KEY=
# Office 365 : IMAP_HOST=outlook.office365.com / SMTP host=smtp.office365.com
IMAP_HOST=outlook.office365.com
IMAP_PORT=993
IMAP_SECURE=true
IMAP_USER=support@mdoservices.fr
IMAP_PASSWORD=change_me
IMAP_FOLDER=INBOX
# Optionnel : dossier ou deplacer les emails traites (laisser vide = juste flag \Seen)
IMAP_PROCESSED_FOLDER=Processed

# -------- Securite (auth & MFA) --------
# Roles pour lesquels la 2FA est obligatoire (separes par virgules).
# Au login, un user dont le role est dans la liste sans 2FA active est
# redirige vers la page de configuration MFA et bloque sur les autres routes.
MFA_REQUIRED_ROLES=ADMIN,MANAGER
# Longueur min du mot de passe (recommande : 12). Applique aux nouveaux MDP
# (creation user, reset, change-password) ; pas au login (compatibilite).
PASSWORD_MIN_LENGTH=12

# -------- Metrics Prometheus (defense en profondeur) --------
# Si defini, /metrics exige Authorization: Bearer <token>. En complement du
# filtre IP Caddy. A activer si on expose le scraper a Internet (Grafana Cloud,
# Datadog). Genere via `openssl rand -hex 32`. Vide = pas de Bearer (compte
# uniquement sur le filtre IP Caddy).
METRICS_BEARER_TOKEN=

# -------- Observabilite (opt-in) --------
# Sentry : decommenter pour activer la capture d'erreurs.
# SENTRY_DSN=https://...@sentry.io/...
# SENTRY_TRACES_SAMPLE_RATE=0.1
# Logger pino : level configurable (trace|debug|info|warn|error)
LOG_LEVEL=info

# -------- Frontend Sentry (opt-in) --------
# NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.05

# -------- Resource limits Docker (optionnel, defauts adaptes a VPS 2vCPU/8Go) --------
# Si non definis, les valeurs par defaut du docker-compose s'appliquent.
# POSTGRES_MEM=1500m
# POSTGRES_CPUS=1.5
# REDIS_MEM=384m
# REDIS_MAXMEMORY=256mb        # eviction LRU au-dela
# REDIS_CPUS=0.5
# BACKEND_MEM=1g
# BACKEND_CPUS=1.5
# FRONTEND_MEM=512m
# FRONTEND_CPUS=1.0

# -------- Timezone --------
TZ=Europe/Paris
