# -------- Domaines --------
DOMAIN=crm.mdoservices.fr
ACME_EMAIL=mathieu@mdoservices.fr

# -------- PostgreSQL --------
POSTGRES_DB=crm_mdo
POSTGRES_USER=crm_mdo
POSTGRES_PASSWORD=change_me_strong_password
DATABASE_URL=postgresql://crm_mdo:change_me_strong_password@postgres:5432/crm_mdo?schema=public

# -------- Redis --------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me_redis_password

# -------- Backend --------
NODE_ENV=production
BACKEND_PORT=4000
JWT_SECRET=change_me_to_a_random_64_char_hex_string
JWT_REFRESH_SECRET=change_me_another_random_64_char_hex_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
CORS_ORIGIN=https://crm.mdoservices.fr

# Alertes renouvellement contrat (jours avant expiration)
CONTRACT_ALERT_DAYS=90,60,30,7

# -------- Frontend --------
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=https://crm.mdoservices.fr/api

# -------- SMTP (emails transactionnels) --------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=no-reply@mdoservices.fr
SMTP_PASSWORD=change_me
SMTP_FROM="CRM MDO Services <no-reply@mdoservices.fr>"
SMTP_SECURE=false

# -------- Timezone --------
TZ=Europe/Paris
