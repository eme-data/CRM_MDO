# -------- Domaines --------
DOMAIN=crm.mdoservices.fr
ACME_EMAIL=mathieu@mdoservices.fr

# -------- PostgreSQL --------
POSTGRES_DB=crm_mdo
POSTGRES_USER=crm_mdo
POSTGRES_PASSWORD=change_me_strong_password
DATABASE_URL=postgresql://crm_mdo:change_me_strong_password@postgres:5432/crm_mdo?schema=public

# -------- Redis --------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me_redis_password

# -------- Backend --------
NODE_ENV=production
BACKEND_PORT=4000
JWT_SECRET=change_me_to_a_random_64_char_hex_string
JWT_REFRESH_SECRET=change_me_another_random_64_char_hex_string
# Cle maitre pour chiffrer les secrets clients (coffre-fort) et secrets 2FA TOTP
# IMPORTANT : ne JAMAIS la changer apres mise en service, sinon les secrets stockes sont perdus
SECRETS_MASTER_KEY=change_me_random_64_char_hex_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
CORS_ORIGIN=https://crm.mdoservices.fr

# Alertes renouvellement contrat (jours avant expiration)
CONTRACT_ALERT_DAYS=90,60,30,7

# -------- Frontend --------
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=https://crm.mdoservices.fr/api

# -------- SMTP (emails transactionnels sortants) --------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=no-reply@mdoservices.fr
SMTP_PASSWORD=change_me
SMTP_FROM="CRM MDO Services <no-reply@mdoservices.fr>"
SMTP_SECURE=false

# -------- IMAP entrant (creation de tickets depuis support@mdoservices.fr) --------
# Mettre INBOUND_EMAIL_ENABLED=true pour activer le polling toutes les 2 min
INBOUND_EMAIL_ENABLED=false
# Envoi auto d'un accuse de reception au client lors de la creation d'un ticket
INBOUND_AUTO_ACK=true
# Taille max d'une piece jointe (en Mo)
MAX_UPLOAD_SIZE_MB=25

# -------- Lookup annuaire entreprises (Pappers / INSEE Sirene) --------
# Au moins une cle requise pour activer la recherche d'entreprises.
# Pappers : recommande, plus complet (capital, dirigeants, NAF + libelle).
#   Inscription : https://www.pappers.fr/api  (gratuit jusqu'a ~250 req/mois)
PAPPERS_API_KEY=
# INSEE Sirene : fallback / alternative gratuite (donnees plus brutes).
#   Inscription : https://api.insee.fr  (cle d'integration X-INSEE-Api-Key-Integration)
SIRENE_API_KEY=
# Office 365 : IMAP_HOST=outlook.office365.com / SMTP host=smtp.office365.com
IMAP_HOST=outlook.office365.com
IMAP_PORT=993
IMAP_SECURE=true
IMAP_USER=support@mdoservices.fr
IMAP_PASSWORD=change_me
IMAP_FOLDER=INBOX
# Optionnel : dossier ou deplacer les emails traites (laisser vide = juste flag \Seen)
IMAP_PROCESSED_FOLDER=Processed

# -------- Timezone --------
TZ=Europe/Paris
