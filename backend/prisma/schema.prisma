// CRM MDO Services - Prisma schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =================== USERS AND TEAMS ===================

enum Role {
  ADMIN
  MANAGER
  SALES
  READONLY
}

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  passwordHash    String
  firstName       String
  lastName        String
  role            Role      @default(SALES)
  isActive        Boolean   @default(true)
  lastLoginAt     DateTime?
  // Signature email pour les replies tickets sortants (texte brut, format libre)
  signature       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  teamId          String?
  team            Team?     @relation(fields: [teamId], references: [id], onDelete: SetNull)

  ownedCompanies     Company[]      @relation("CompanyOwner")
  ownedContacts      Contact[]      @relation("ContactOwner")
  ownedOpportunities Opportunity[]  @relation("OpportunityOwner")
  ownedContracts     Contract[]     @relation("ContractOwner")
  assignedTasks      Task[]         @relation("TaskAssignee")
  createdTasks       Task[]         @relation("TaskCreator")
  assignedTickets    Ticket[]       @relation("TicketAssignee")
  createdTickets     Ticket[]       @relation("TicketCreator")
  ticketMessages     TicketMessage[]
  uploadedAttachments Attachment[]  @relation("AttachmentUploader")
  notes              Note[]
  activities         Activity[]
  refreshTokens      RefreshToken[]
  interventions      Intervention[] @relation("InterventionTechnician")

  @@index([teamId])
}

model Team {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]
}

model RefreshToken {
  id        String    @id @default(uuid())
  token     String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

// =================== COMPANIES AND CONTACTS ===================

enum CompanyStatus {
  LEAD
  PROSPECT
  CUSTOMER
  INACTIVE
}

enum CompanySector {
  PME
  TPE
  COLLECTIVITE
  SANTE
  INDUSTRIE
  EDUCATION
  ASSOCIATION
  AUTRE
}

model Company {
  id          String        @id @default(uuid())
  name        String
  // Identifiants legaux (sources : Pappers / INSEE Sirene)
  siret       String?       @unique
  siren       String?       @unique
  apeCode     String?       // ex: "62.02A"
  apeLabel    String?       // ex: "Conseil en systemes et logiciels informatiques"
  legalForm   String?       // ex: "SARL", "SAS", "SASU"
  creationDate DateTime?    // date de creation entreprise
  capitalSocial Decimal?    @db.Decimal(14, 2)
  lastSyncedAt DateTime?    // derniere synchro avec annuaire externe
  // Donnees CRM
  sector      CompanySector @default(PME)
  status      CompanyStatus @default(LEAD)
  employees   Int?
  website     String?
  phone       String?
  email       String?
  address     String?
  postalCode  String?
  city        String?
  country     String?       @default("France")
  notes       String?

  ownerId     String?
  owner       User?         @relation("CompanyOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  contacts       Contact[]
  opportunities  Opportunity[]
  contracts      Contract[]
  tasks          Task[]
  notesRel       Note[]
  interventions  Intervention[]
  tickets        Ticket[]

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([ownerId])
  @@index([status])
  @@index([name])
  @@index([siren])
}

model Contact {
  id          String   @id @default(uuid())
  firstName   String
  lastName    String
  email       String?
  phone       String?
  mobile      String?
  position    String?
  isPrimary   Boolean  @default(false)
  notes       String?

  companyId   String?
  company     Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  ownerId     String?
  owner       User?    @relation("ContactOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  tasks       Task[]
  notesRel    Note[]
  tickets     Ticket[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyId])
  @@index([ownerId])
  @@index([email])
}

// =================== OPPORTUNITIES ===================

enum OpportunityStage {
  QUALIFICATION
  PROPOSITION
  NEGOCIATION
  GAGNE
  PERDU
}

model Opportunity {
  id                String           @id @default(uuid())
  title             String
  stage             OpportunityStage @default(QUALIFICATION)
  amountHt          Decimal          @default(0) @db.Decimal(12, 2)
  probability       Int              @default(50)
  expectedCloseDate DateTime?
  closedAt          DateTime?
  lostReason        String?
  description       String?

  companyId         String
  company           Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)

  ownerId           String?
  owner             User?            @relation("OpportunityOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  contracts         Contract[]
  tasks             Task[]
  notesRel          Note[]

  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([companyId])
  @@index([ownerId])
  @@index([stage])
}

// =================== CONTRACTS (core business need) ===================

enum ContractOffer {
  MDO_ESSENTIEL
  MDO_PRO
  MDO_SOUVERAIN
  CUSTOM
}

enum ContractStatus {
  DRAFT
  ACTIVE
  SUSPENDED
  EXPIRED
  TERMINATED
  RENEWED
}

enum BillingPeriod {
  MONTHLY
  QUARTERLY
  YEARLY
}

model Contract {
  id                 String         @id @default(uuid())
  reference          String         @unique
  title              String
  offer              ContractOffer  @default(MDO_ESSENTIEL)
  status             ContractStatus @default(DRAFT)

  startDate          DateTime
  endDate            DateTime
  signedAt           DateTime?

  engagementMonths   Int            @default(12)
  billingPeriod      BillingPeriod  @default(MONTHLY)
  unitPriceHt        Decimal        @db.Decimal(10, 2)
  quantity           Int            @default(1)
  monthlyAmountHt    Decimal        @db.Decimal(12, 2)
  setupFeeHt         Decimal?       @db.Decimal(10, 2)
  vatRate            Decimal        @default(20) @db.Decimal(5, 2)

  autoRenew          Boolean        @default(true)
  noticePeriodMonths Int            @default(3)
  terminatedAt       DateTime?
  terminationReason  String?

  companyId          String
  company            Company        @relation(fields: [companyId], references: [id], onDelete: Restrict)

  opportunityId      String?
  opportunity        Opportunity?   @relation(fields: [opportunityId], references: [id], onDelete: SetNull)

  ownerId            String?
  owner              User?          @relation("ContractOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  previousContractId String?        @unique
  previousContract   Contract?      @relation("ContractRenewal", fields: [previousContractId], references: [id], onDelete: SetNull)
  nextContract       Contract?      @relation("ContractRenewal")

  description        String?

  alerts             ContractRenewalAlert[]
  tasks              Task[]
  notesRel           Note[]
  interventions      Intervention[]
  tickets            Ticket[]

  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([companyId])
  @@index([ownerId])
  @@index([status])
  @@index([endDate])
}

model ContractRenewalAlert {
  id          String    @id @default(uuid())
  contractId  String
  contract    Contract  @relation(fields: [contractId], references: [id], onDelete: Cascade)
  daysBefore  Int
  alertDate   DateTime
  sentAt      DateTime?
  resolved    Boolean   @default(false)
  createdAt   DateTime  @default(now())

  @@index([contractId])
  @@index([alertDate, sentAt])
}

// =================== INTERVENTIONS ===================

enum InterventionType {
  ONSITE
  REMOTE
  PHONE
}

enum InterventionStatus {
  PLANNED
  IN_PROGRESS
  DONE
  CANCELLED
}

model Intervention {
  id           String             @id @default(uuid())
  title        String
  type         InterventionType   @default(REMOTE)
  status       InterventionStatus @default(PLANNED)
  scheduledAt  DateTime
  startedAt    DateTime?
  endedAt      DateTime?
  durationMin  Int?
  description  String?
  report       String?

  companyId    String
  company      Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)

  contractId   String?
  contract     Contract?          @relation(fields: [contractId], references: [id], onDelete: SetNull)

  ticketId     String?
  ticket       Ticket?            @relation(fields: [ticketId], references: [id], onDelete: SetNull)

  technicianId String?
  technician   User?              @relation("InterventionTechnician", fields: [technicianId], references: [id], onDelete: SetNull)

  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([companyId])
  @@index([contractId])
  @@index([technicianId])
  @@index([scheduledAt])
}

// =================== TASKS / NOTES / ACTIVITY ===================

enum TaskPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum TaskStatus {
  TODO
  DOING
  DONE
  CANCELLED
}

model Task {
  id            String       @id @default(uuid())
  title         String
  description   String?
  priority      TaskPriority @default(NORMAL)
  status        TaskStatus   @default(TODO)
  dueDate       DateTime?
  completedAt   DateTime?

  createdById   String
  createdBy     User         @relation("TaskCreator", fields: [createdById], references: [id], onDelete: Restrict)
  assigneeId    String?
  assignee      User?        @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  companyId     String?
  company       Company?     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contactId     String?
  contact       Contact?     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  opportunityId String?
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  contractId    String?
  contract      Contract?    @relation(fields: [contractId], references: [id], onDelete: Cascade)

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([assigneeId])
  @@index([status])
  @@index([dueDate])
}

model Note {
  id            String       @id @default(uuid())
  content       String
  authorId      String
  author        User         @relation(fields: [authorId], references: [id], onDelete: Restrict)

  companyId     String?
  company       Company?     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contactId     String?
  contact       Contact?     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  opportunityId String?
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  contractId    String?
  contract      Contract?    @relation(fields: [contractId], references: [id], onDelete: Cascade)

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([authorId])
  @@index([companyId])
}

model Activity {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action     String
  entity     String
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
}

// =================== EMAILS ===================

model EmailTemplate {
  id         String   @id @default(uuid())
  key        String   @unique
  name       String
  subject    String
  bodyHtml   String
  bodyText   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

enum EmailStatus {
  QUEUED
  SENT
  FAILED
}

model Setting {
  key         String   @id
  value       String?
  isSecret    Boolean  @default(false)
  category    String   @default("general")
  label       String?
  description String?
  updatedAt   DateTime @default(now()) @updatedAt
  updatedById String?

  @@index([category])
}

model EmailLog {
  id              String      @id @default(uuid())
  toEmail         String
  subject         String
  bodyHtml        String
  status          EmailStatus @default(QUEUED)
  error           String?
  relatedEntity   String?
  relatedEntityId String?
  sentAt          DateTime?
  createdAt       DateTime    @default(now())

  @@index([status])
  @@index([toEmail])
}

// =================== TICKETS (support client) ===================

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_CUSTOMER
  RESOLVED
  CLOSED
  CANCELLED
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum TicketCategory {
  INCIDENT
  REQUEST
  QUESTION
  BUG
  OTHER
}

enum TicketChannel {
  PORTAL
  EMAIL
  PHONE
  ONSITE
  INTERNAL
}

model Ticket {
  id              String         @id @default(uuid())
  reference       String         @unique
  title           String
  description     String
  status          TicketStatus   @default(OPEN)
  priority        TicketPriority @default(NORMAL)
  category        TicketCategory @default(INCIDENT)
  channel         TicketChannel  @default(INTERNAL)

  firstResponseAt DateTime?
  resolvedAt      DateTime?
  closedAt        DateTime?
  dueDate         DateTime?

  companyId       String
  company         Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)

  contactId       String?
  contact         Contact?       @relation(fields: [contactId], references: [id], onDelete: SetNull)

  contractId      String?
  contract        Contract?      @relation(fields: [contractId], references: [id], onDelete: SetNull)

  assigneeId      String?
  assignee        User?          @relation("TicketAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  createdById     String
  createdBy       User           @relation("TicketCreator", fields: [createdById], references: [id], onDelete: Restrict)

  messages        TicketMessage[]
  interventions   Intervention[]
  attachments     Attachment[]

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([companyId])
  @@index([assigneeId])
  @@index([status])
  @@index([priority])
  @@index([reference])
}

model TicketMessage {
  id          String   @id @default(uuid())
  ticketId    String
  ticket      Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId    String?
  author      User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  authorName  String?
  authorEmail String?
  content     String
  isInternal  Boolean  @default(false)
  // Email threading
  messageId   String?  @unique  // Message-ID pour les emails (entrants ou sortants)
  inReplyTo   String?  // In-Reply-To header (chaining)
  viaEmail    Boolean  @default(false)  // true si message issu d'un email
  // CC / BCC (texte simple separe par virgules)
  cc          String?
  bcc         String?
  attachments Attachment[]
  createdAt   DateTime @default(now())

  @@index([ticketId])
  @@index([inReplyTo])
}

// =================== ATTACHMENTS ===================

model Attachment {
  id           String         @id @default(uuid())
  filename     String         // nom de fichier original cote client
  storageKey   String         @unique // chemin / UUID de stockage sur disque
  mimeType     String
  sizeBytes    Int

  uploadedById String?
  uploadedBy   User?          @relation("AttachmentUploader", fields: [uploadedById], references: [id], onDelete: SetNull)

  // Liens polymorphes : un attachment peut etre attache a un ticket directement
  // ou a un message specifique du ticket
  ticketId     String?
  ticket       Ticket?        @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  ticketMessageId String?
  ticketMessage   TicketMessage? @relation(fields: [ticketMessageId], references: [id], onDelete: Cascade)

  createdAt    DateTime       @default(now())

  @@index([ticketId])
  @@index([ticketMessageId])
}
