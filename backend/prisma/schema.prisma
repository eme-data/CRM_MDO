// CRM MDO Services - Prisma schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =================== USERS AND TEAMS ===================

enum Role {
  ADMIN
  MANAGER
  SALES
  READONLY
}

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  passwordHash    String
  firstName       String
  lastName        String
  role            Role      @default(SALES)
  isActive        Boolean   @default(true)
  lastLoginAt     DateTime?
  // Signature email pour les replies tickets sortants (texte brut, format libre)
  signature       String?
  // Token opaque pour l'export iCal authentifie (les clients calendrier ne
  // supportent pas Bearer). NULL tant que l'utilisateur n'a pas active la
  // fonctionnalite ; revoquable via /users/me/ical/regenerate.
  icalToken       String?   @unique
  // Taux horaire interne (cout du technicien pour MDO). Sert au calcul de
  // marge / rentabilite (cf module profitability). Si null, on utilise la
  // valeur par defaut Settings('profitability.defaultHourlyRate').
  // Ne PAS confondre avec un eventuel taux horaire de facturation client —
  // celui-ci est porte par le contrat / time entry.
  hourlyRate      Decimal?  @db.Decimal(8, 2)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  teamId          String?
  team            Team?     @relation(fields: [teamId], references: [id], onDelete: SetNull)

  ownedCompanies     Company[]      @relation("CompanyOwner")
  ownedContacts      Contact[]      @relation("ContactOwner")
  ownedOpportunities Opportunity[]  @relation("OpportunityOwner")
  ownedContracts     Contract[]     @relation("ContractOwner")
  assignedTasks      Task[]         @relation("TaskAssignee")
  createdTasks       Task[]         @relation("TaskCreator")
  assignedTickets    Ticket[]       @relation("TicketAssignee")
  createdTickets     Ticket[]       @relation("TicketCreator")
  ticketMessages     TicketMessage[]
  uploadedAttachments Attachment[]  @relation("AttachmentUploader")
  timeEntries        TimeEntry[]
  invoicedTimeEntries TimeEntry[]   @relation("TimeEntryInvoicer")
  notifications      Notification[]
  responseTemplates  ResponseTemplate[]
  authoredDocPages   DocPage[]      @relation("DocPageAuthor")
  createdSecrets     SecretEntry[]  @relation("SecretEntryCreator")
  mfa                UserMfa?
  notes              Note[]
  activities         Activity[]
  refreshTokens      RefreshToken[]
  interventions      Intervention[] @relation("InterventionTechnician")
  recurringTemplatesCreated  RecurringTaskTemplate[] @relation("RecurringTemplateCreator")
  recurringTemplatesAssigned RecurringTaskTemplate[] @relation("RecurringTemplateAssignee")
  workflowRulesCreated   WorkflowRule[]  @relation("WorkflowRuleCreator")
  workflowRulesAssigned  WorkflowRule[]  @relation("WorkflowRuleAssignee")
  ownedQuotes            Quote[]         @relation("QuoteOwner")
  signatureRequests      SignatureRequest[] @relation("SignatureRequestCreator")
  callLogs               CallLog[]
  aiUsage                AiUsage[]
  pushSubscriptions      PushSubscription[]
  createdApiKeys         ApiKey[]                          @relation("ApiKeyCreator")
  onboardingStepsAssigned OnboardingRunStep[]              @relation("OnboardingStepAssignee")
  onboardingStepsClosed   OnboardingRunStep[]              @relation("OnboardingStepCloser")
  kbArticles              KbArticle[]                      @relation("KbArticleAuthor")
  customerSuccessReviews  CustomerSuccessReview[]          @relation("CustomerSuccessReviewOwner")
  complianceAssessments  ComplianceAssessment[]            @relation("ComplianceOwner")
  controlReviews         ComplianceControlAssessment[]     @relation("ControlReviewer")

  @@index([teamId])
}

model Team {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]
}

model RefreshToken {
  id          String    @id @default(uuid())
  token       String    @unique
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Metadata utilisee par l'UI sessions/devices (pas de fingerprinting fort,
  // juste une etiquette informelle pour aider l'utilisateur a reconnaitre la session).
  userAgent   String?
  ip          String?
  lastUsedAt  DateTime?
  expiresAt   DateTime
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId])
}

// =================== COMPANIES AND CONTACTS ===================

enum CompanyStatus {
  LEAD
  PROSPECT
  CUSTOMER
  INACTIVE
}

enum CompanySector {
  PME
  TPE
  COLLECTIVITE
  SANTE
  INDUSTRIE
  EDUCATION
  ASSOCIATION
  AUTRE
}

model Company {
  id          String        @id @default(uuid())
  name        String
  // Identifiants legaux (sources : Pappers / INSEE Sirene)
  siret       String?       @unique
  siren       String?       @unique
  apeCode     String?       // ex: "62.02A"
  apeLabel    String?       // ex: "Conseil en systemes et logiciels informatiques"
  legalForm   String?       // ex: "SARL", "SAS", "SASU"
  creationDate DateTime?    // date de creation entreprise
  capitalSocial Decimal?    @db.Decimal(14, 2)
  lastSyncedAt DateTime?    // derniere synchro avec annuaire externe
  // Donnees CRM
  sector      CompanySector @default(PME)
  status      CompanyStatus @default(LEAD)
  employees   Int?
  website     String?
  phone       String?
  email       String?
  address     String?
  postalCode  String?
  city        String?
  country     String?       @default("France")
  notes       String?

  ownerId     String?
  owner       User?         @relation("CompanyOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  // Identifiants externes (outils de facturation tiers)
  // @deprecated 2026-05 : Sellsy retire du stack MDO. Champ conserve pour ne
  // pas perdre les references historiques des companies deja synchronisees
  // dans Sellsy. Plus aucune ecriture cote code.
  sellsyId    String?       @unique
  qontoClientId String?     @unique  // ID du client dans Qonto Factures

  contacts       Contact[]
  opportunities  Opportunity[]
  contracts      Contract[]
  tasks          Task[]
  notesRel       Note[]
  interventions  Intervention[]
  tickets        Ticket[]
  assets         Asset[]
  docPages       DocPage[]
  secrets        SecretEntry[]
  invoices       Invoice[]
  bankTransactions BankTransaction[]
  locations      Location[]
  networks       Network[]
  flexibleAssets FlexibleAsset[]
  quickNotes     QuickNote[]
  runbookRuns    RunbookRun[]
  uptimeMonitors UptimeMonitor[]
  clientReports  ClientReport[]
  timeEntries    TimeEntry[]
  portalUsers    ClientPortalUser[]
  m365Tenant     M365Tenant?
  recurringTemplates RecurringTaskTemplate[]
  quotes         Quote[]
  signatureRequests SignatureRequest[]
  callLogs       CallLog[]
  complianceAssessments ComplianceAssessment[]
  apiKeys        ApiKey[]
  onboardingRuns OnboardingRun[]
  kbArticles     KbArticle[]
  emailSecurityChecks EmailSecurityCheck[]
  phishingCampaigns PhishingCampaign[]
  customerSuccessReviews CustomerSuccessReview[]
  dripEnrollments        DripEnrollment[]
  backupJobs             BackupJob[]

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([ownerId])
  @@index([status])
  @@index([name])
  @@index([siren])
}

model Contact {
  id          String   @id @default(uuid())
  firstName   String
  lastName    String
  email       String?
  phone       String?
  mobile      String?
  position    String?
  isPrimary   Boolean  @default(false)
  notes       String?

  companyId   String?
  company     Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  ownerId     String?
  owner       User?    @relation("ContactOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  tasks       Task[]
  notesRel    Note[]
  tickets     Ticket[]
  portalUsers ClientPortalUser[] @relation("ContactPortalUser")
  quotes      Quote[]
  callLogs    CallLog[]
  dripEnrollments DripEnrollment[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyId])
  @@index([ownerId])
  @@index([email])
}

// =================== OPPORTUNITIES ===================

enum OpportunityStage {
  QUALIFICATION
  PROPOSITION
  NEGOCIATION
  GAGNE
  PERDU
}

// Motifs structures pour les opportunites perdues. Permet l'agregation
// statistique pour le module win/loss analysis. Le champ lostReason texte
// libre existe deja en plus pour les details.
enum OpportunityLossReason {
  PRICE              // trop cher / hors budget
  COMPETITOR         // concurrent retenu (cf competitorName)
  TIMING             // pas le bon moment cote client
  FEATURE            // manque une fonctionnalite
  NO_RESPONSE        // ghost / pas de retour
  BUDGET             // pas de budget
  PROJECT_CANCELLED  // projet client annule
  OTHER
}

enum OpportunityWinReason {
  PRICE_LOWEST       // proposition la moins chere
  REPUTATION         // notoriete MDO / recommandation
  RELATIONSHIP       // relation existante / confiance
  FEATURE            // fonctionnalite distinctive
  PROXIMITY          // proximite geo / disponibilite
  REFERRAL           // recommande par client existant
  OTHER
}

model Opportunity {
  id                String           @id @default(uuid())
  title             String
  stage             OpportunityStage @default(QUALIFICATION)
  amountHt          Decimal          @default(0) @db.Decimal(12, 2)
  probability       Int              @default(50)
  expectedCloseDate DateTime?
  closedAt          DateTime?
  // Champ historique texte libre — conserve pour ne pas perdre les motifs
  // saisis avant l'introduction des enums structures.
  lostReason        String?
  // ----- Win/loss analysis (motifs structures) -----
  // Structure : a renseigner au passage en GAGNE/PERDU pour permettre
  // l'agregation statistique (cf module win/loss + dashboard exec).
  lossReasonCode    OpportunityLossReason?
  winReasonCode     OpportunityWinReason?
  competitorName    String?          // utile si lossReasonCode=COMPETITOR
  description       String?

  companyId         String
  company           Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)

  ownerId           String?
  owner             User?            @relation("OpportunityOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  contracts         Contract[]
  tasks             Task[]
  notesRel          Note[]
  quotes            Quote[]

  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([companyId])
  @@index([ownerId])
  @@index([stage])
  @@index([lossReasonCode])
  @@index([winReasonCode])
}

// =================== CONTRACTS (core business need) ===================

enum ContractOffer {
  MDO_ESSENTIEL
  MDO_PRO
  MDO_SOUVERAIN
  CUSTOM
}

enum ContractStatus {
  DRAFT
  ACTIVE
  SUSPENDED
  EXPIRED
  TERMINATED
  RENEWED
}

enum BillingPeriod {
  MONTHLY
  QUARTERLY
  YEARLY
}

model Contract {
  id                 String         @id @default(uuid())
  reference          String         @unique
  title              String
  offer              ContractOffer  @default(MDO_ESSENTIEL)
  status             ContractStatus @default(DRAFT)

  startDate          DateTime
  endDate            DateTime
  signedAt           DateTime?

  engagementMonths   Int            @default(12)
  billingPeriod      BillingPeriod  @default(MONTHLY)
  unitPriceHt        Decimal        @db.Decimal(10, 2)
  quantity           Int            @default(1)
  monthlyAmountHt    Decimal        @db.Decimal(12, 2)
  setupFeeHt         Decimal?       @db.Decimal(10, 2)
  vatRate            Decimal        @default(20) @db.Decimal(5, 2)

  autoRenew          Boolean        @default(true)
  noticePeriodMonths Int            @default(3)
  terminatedAt       DateTime?
  terminationReason  String?

  companyId          String
  company            Company        @relation(fields: [companyId], references: [id], onDelete: Restrict)

  opportunityId      String?
  opportunity        Opportunity?   @relation(fields: [opportunityId], references: [id], onDelete: SetNull)

  ownerId            String?
  owner              User?          @relation("ContractOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  previousContractId String?        @unique
  previousContract   Contract?      @relation("ContractRenewal", fields: [previousContractId], references: [id], onDelete: SetNull)
  nextContract       Contract?      @relation("ContractRenewal")

  // Synchronisation outil de facturation externe
  // @deprecated 2026-05 : Sellsy retire du stack MDO. Champ conserve pour
  // ne pas perdre les references historiques d'abonnements deja synchronises.
  sellsySubscriptionId String?      @unique
  externalSyncedAt   DateTime?

  description        String?

  alerts             ContractRenewalAlert[]
  tasks              Task[]
  notesRel           Note[]
  interventions      Intervention[]
  tickets            Ticket[]
  timeEntries        TimeEntry[]
  assets             Asset[]
  invoices           Invoice[]
  recurringTemplates RecurringTaskTemplate[]
  // Quote dont la conversion a cree ce contrat (1-1, optional). Nomme via la
  // relation "ContractFromQuote" pour eviter le conflit avec d'autres relations
  // potentielles avec Quote a l'avenir.
  fromQuote          Quote?         @relation("ContractFromQuote")
  onboardingRun      OnboardingRun?

  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([companyId])
  @@index([ownerId])
  @@index([status])
  @@index([endDate])
  // Compositie pour le cron renewal-alerts (filtre status=ACTIVE + endDate BETWEEN now AND now+90d)
  // et pour stats() dashboard. Reduit le bookmark lookup quand on a >1000 contrats.
  @@index([status, endDate])
}

model ContractRenewalAlert {
  id          String    @id @default(uuid())
  contractId  String
  contract    Contract  @relation(fields: [contractId], references: [id], onDelete: Cascade)
  daysBefore  Int
  alertDate   DateTime
  sentAt      DateTime?
  resolved    Boolean   @default(false)
  createdAt   DateTime  @default(now())

  @@index([contractId])
  @@index([alertDate, sentAt])
}

// =================== INTERVENTIONS ===================

enum InterventionType {
  ONSITE
  REMOTE
  PHONE
}

enum InterventionStatus {
  PLANNED
  IN_PROGRESS
  DONE
  CANCELLED
}

model Intervention {
  id           String             @id @default(uuid())
  title        String
  type         InterventionType   @default(REMOTE)
  status       InterventionStatus @default(PLANNED)
  scheduledAt  DateTime
  startedAt    DateTime?
  endedAt      DateTime?
  durationMin  Int?
  description  String?
  report       String?

  companyId    String
  company      Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)

  contractId   String?
  contract     Contract?          @relation(fields: [contractId], references: [id], onDelete: SetNull)

  ticketId     String?
  ticket       Ticket?            @relation(fields: [ticketId], references: [id], onDelete: SetNull)

  technicianId String?
  technician   User?              @relation("InterventionTechnician", fields: [technicianId], references: [id], onDelete: SetNull)

  timeEntries  TimeEntry[]

  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([companyId])
  @@index([contractId])
  @@index([technicianId])
  @@index([scheduledAt])
}

// =================== TASKS / NOTES / ACTIVITY ===================

enum TaskPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum TaskStatus {
  TODO
  DOING
  DONE
  CANCELLED
}

model Task {
  id            String       @id @default(uuid())
  title         String
  description   String?
  priority      TaskPriority @default(NORMAL)
  status        TaskStatus   @default(TODO)
  dueDate       DateTime?
  completedAt   DateTime?

  createdById   String
  createdBy     User         @relation("TaskCreator", fields: [createdById], references: [id], onDelete: Restrict)
  assigneeId    String?
  assignee      User?        @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  companyId     String?
  company       Company?     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contactId     String?
  contact       Contact?     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  opportunityId String?
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  contractId    String?
  contract      Contract?    @relation(fields: [contractId], references: [id], onDelete: Cascade)

  // Trace de l'origine recurrente : si cette Task a ete generee automatiquement
  // par un RecurringTaskTemplate, on garde la reference pour pouvoir afficher
  // "Tache generee depuis le modele 'Check backup mensuel'" + permettre la
  // suppression en cascade quand on supprime le modele.
  recurringTemplateId String?
  recurringTemplate   RecurringTaskTemplate? @relation(fields: [recurringTemplateId], references: [id], onDelete: SetNull)

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([assigneeId])
  @@index([status])
  @@index([dueDate])
  // Composite kanban : SELECT WHERE status=X ORDER BY dueDate (page tasks).
  @@index([status, dueDate])
  // FKs souvent filtrees mais sans index dedie (cascade depuis Company/Contact/...).
  @@index([companyId])
  @@index([contractId])
  @@index([recurringTemplateId])
}

// =================== RECURRING TASK TEMPLATES ===================
//
// Modeles de taches recurrentes auto-generees par cron : "Check backup mensuel
// client X", "Revue trimestriel client Y", "Patch management mensuel global", etc.
// Le cron tourne une fois par jour ; pour chaque template dont nextRunAt <= now,
// il cree une Task et recalcule nextRunAt selon la frequence.
//
// Scope : si companyId est defini, la Task generee sera rattachee a cette societe.
// Sinon (template global) la Task est cree sans rattachement direct mais reste
// visible dans /tasks pour l'assignee.

enum RecurringFrequency {
  WEEKLY      // tous les 7 jours
  MONTHLY     // tous les mois (au dayOfMonth si defini, sinon meme date que startsOn)
  QUARTERLY   // tous les 3 mois
  YEARLY      // tous les ans
}

model RecurringTaskTemplate {
  id              String              @id @default(uuid())
  name            String              // libelle modele ("Check backup mensuel")
  // Champs reproduits sur chaque Task generee :
  title           String              // titre de la Task (peut contenir le mois pour mensuel)
  description     String?
  priority        TaskPriority        @default(NORMAL)
  // Generation : on cree la Task a la prochaine date prevue (nextRunAt), avec
  // dueDate = generatedAt + dueDateOffsetDays. Permet "Generee le 1er du mois,
  // a faire pour le 15".
  dueDateOffsetDays Int               @default(7)
  frequency       RecurringFrequency  @default(MONTHLY)
  // Jour du mois pour MONTHLY/QUARTERLY/YEARLY (1-28 pour eviter les soucis de
  // fevrier). Null = on prend le jour du startsOn comme reference.
  dayOfMonth      Int?
  // Date de demarrage et arret optionnel
  startsOn        DateTime            @default(now())
  endsOn          DateTime?
  // Prochain horodatage attendu de generation (recalcule apres chaque run).
  nextRunAt       DateTime
  lastRunAt       DateTime?
  // Compteur d'instances generees (info admin, pas critique)
  generatedCount  Int                 @default(0)
  isActive        Boolean             @default(true)
  // Rattachements optionnels appliques aux Tasks generees
  companyId       String?
  company         Company?            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  assigneeId      String?
  assignee        User?               @relation("RecurringTemplateAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  contractId      String?
  contract        Contract?           @relation(fields: [contractId], references: [id], onDelete: SetNull)
  // Audit
  createdById     String
  createdBy       User                @relation("RecurringTemplateCreator", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  tasks           Task[]

  @@index([nextRunAt, isActive])
  @@index([companyId])
}

model Note {
  id            String       @id @default(uuid())
  content       String
  authorId      String
  author        User         @relation(fields: [authorId], references: [id], onDelete: Restrict)

  companyId     String?
  company       Company?     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contactId     String?
  contact       Contact?     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  opportunityId String?
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  contractId    String?
  contract      Contract?    @relation(fields: [contractId], references: [id], onDelete: Cascade)

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([authorId])
  @@index([companyId])
}

model Activity {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action     String
  entity     String
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  // ===== Hash chaine (preuve d'integrite NIS2 / RGPD) =====
  // currentHash = SHA256( prevHash || canonicalSerialize(entry) )
  // - prevHash null sur la 1ere entry de la chaine (genesis)
  // - currentHash null tant que pas encore scelle (cron toutes les 5 min)
  // Une alteration retroactive sur entry N casse currentHash de N et
  // toutes les entries N+1, N+2... car prevHash[N+1] != calc(N).
  // Verifiable via POST /audit/verify.
  prevHash   String?
  currentHash String?
  // Sequence numerique pour ordre stable (createdAt n'est pas garanti unique
  // sur un meme tick). Auto-attribue lors du sealing.
  sequence   Int?     @unique

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@index([currentHash])
}

// =================== EMAILS ===================

model EmailTemplate {
  id         String   @id @default(uuid())
  key        String   @unique
  name       String
  subject    String
  bodyHtml   String
  bodyText   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

enum EmailStatus {
  QUEUED
  SENT
  FAILED
}

model Setting {
  key         String   @id
  value       String?
  isSecret    Boolean  @default(false)
  category    String   @default("general")
  label       String?
  description String?
  updatedAt   DateTime @default(now()) @updatedAt
  updatedById String?

  @@index([category])
}

model EmailLog {
  id              String      @id @default(uuid())
  toEmail         String
  subject         String
  bodyHtml        String
  status          EmailStatus @default(QUEUED)
  error           String?
  relatedEntity   String?
  relatedEntityId String?
  sentAt          DateTime?
  createdAt       DateTime    @default(now())

  @@index([status])
  @@index([toEmail])
  // Permet de retrouver rapidement tous les emails lies a une entite donnee
  // (contrat, ticket, societe...) pour l'historique des relations.
  @@index([relatedEntity, relatedEntityId])
}

// =================== TICKETS (support client) ===================

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_CUSTOMER
  RESOLVED
  CLOSED
  CANCELLED
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum TicketCategory {
  INCIDENT
  REQUEST
  QUESTION
  BUG
  OTHER
}

enum TicketChannel {
  PORTAL
  EMAIL
  PHONE
  ONSITE
  INTERNAL
}

model Ticket {
  id              String         @id @default(uuid())
  reference       String         @unique
  title           String
  description     String
  status          TicketStatus   @default(OPEN)
  priority        TicketPriority @default(NORMAL)
  category        TicketCategory @default(INCIDENT)
  channel         TicketChannel  @default(INTERNAL)

  firstResponseAt DateTime?
  resolvedAt      DateTime?
  closedAt        DateTime?
  dueDate         DateTime?

  companyId       String
  company         Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)

  contactId       String?
  contact         Contact?       @relation(fields: [contactId], references: [id], onDelete: SetNull)

  contractId      String?
  contract        Contract?      @relation(fields: [contractId], references: [id], onDelete: SetNull)

  assigneeId      String?
  assignee        User?          @relation("TicketAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  createdById     String
  createdBy       User           @relation("TicketCreator", fields: [createdById], references: [id], onDelete: Restrict)

  messages        TicketMessage[]
  interventions   Intervention[]
  attachments     Attachment[]
  timeEntries     TimeEntry[]
  satisfaction    TicketSatisfaction?

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([companyId])
  @@index([assigneeId])
  @@index([status])
  @@index([priority])
  @@index([reference])
  // Composite pour le kanban (ORDER BY priority DESC, createdAt DESC) et le
  // filtre commun status+priority des dashboards techniciens.
  @@index([status, priority])
  // Composite pour le compteur "overdue" : status IN (...) AND dueDate < NOW.
  @@index([status, dueDate])
}

model TicketMessage {
  id          String   @id @default(uuid())
  ticketId    String
  ticket      Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId    String?
  author      User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  authorName  String?
  authorEmail String?
  content     String
  isInternal  Boolean  @default(false)
  // Email threading
  messageId   String?  @unique  // Message-ID pour les emails (entrants ou sortants)
  inReplyTo   String?  // In-Reply-To header (chaining)
  viaEmail    Boolean  @default(false)  // true si message issu d'un email
  // CC / BCC (texte simple separe par virgules)
  cc          String?
  bcc         String?
  attachments Attachment[]
  createdAt   DateTime @default(now())

  @@index([ticketId])
  @@index([inReplyTo])
}

// =================== ATTACHMENTS ===================

model Attachment {
  id           String         @id @default(uuid())
  filename     String         // nom de fichier original cote client
  storageKey   String         @unique // chemin / UUID de stockage sur disque
  mimeType     String
  sizeBytes    Int

  uploadedById String?
  uploadedBy   User?          @relation("AttachmentUploader", fields: [uploadedById], references: [id], onDelete: SetNull)

  // Liens polymorphes : un attachment peut etre attache a un ticket directement
  // ou a un message specifique du ticket
  ticketId     String?
  ticket       Ticket?        @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  ticketMessageId String?
  ticketMessage   TicketMessage? @relation(fields: [ticketMessageId], references: [id], onDelete: Cascade)

  createdAt    DateTime       @default(now())

  @@index([ticketId])
  @@index([ticketMessageId])
}

// =================== TIME TRACKING ===================

model TimeEntry {
  id            String        @id @default(uuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  startedAt     DateTime
  endedAt       DateTime?
  durationMin   Int?
  description   String?
  billable      Boolean       @default(true)
  // Taux horaire applique (HT). Optionnel : si null au moment de la facturation,
  // on retombe sur le taux defini au niveau du contrat ou un defaut global.
  hourlyRateHt  Decimal?      @db.Decimal(10, 2)

  // Rattachement client : direct (saisie libre depuis /time) ou implicite via
  // ticket/intervention/contract. Le service de facturation agregera en
  // priorite par companyId, sinon par companyId du ticket/intervention/contract.
  companyId      String?
  company        Company?      @relation(fields: [companyId], references: [id], onDelete: SetNull)
  ticketId       String?
  ticket         Ticket?       @relation(fields: [ticketId], references: [id], onDelete: SetNull)
  interventionId String?
  intervention   Intervention? @relation(fields: [interventionId], references: [id], onDelete: SetNull)
  contractId     String?
  contract       Contract?     @relation(fields: [contractId], references: [id], onDelete: SetNull)

  // Suivi de la facturation : quand l'entree a-t-elle ete poussee dans Sellsy/
  // Qonto ? `invoiceReference` peut etre l'ID Sellsy de la facture brouillon,
  // un n. de facture, ou un libre texte. Permet le filtre "non facturees" pour
  // la page admin de billing.
  invoicedAt        DateTime?
  invoiceReference  String?
  invoicedById      String?
  invoicedBy        User?     @relation("TimeEntryInvoicer", fields: [invoicedById], references: [id], onDelete: SetNull)

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([userId, startedAt])
  @@index([ticketId])
  @@index([interventionId])
  @@index([contractId])
  @@index([companyId, invoicedAt])
  @@index([invoicedAt])
}

// =================== NOTIFICATIONS IN-APP ===================

enum NotificationType {
  TICKET_ASSIGNED
  TICKET_NEW_MESSAGE
  TICKET_OVERDUE
  CONTRACT_EXPIRING
  TASK_ASSIGNED
  INTERVENTION_REMINDER
  GENERIC
}

model Notification {
  id         String           @id @default(uuid())
  userId     String
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       NotificationType @default(GENERIC)
  title      String
  body       String?
  entity     String?
  entityId   String?
  url        String?
  readAt     DateTime?
  createdAt  DateTime         @default(now())

  @@index([userId, readAt])
  @@index([createdAt])
}

// =================== RESPONSE TEMPLATES ===================

model ResponseTemplate {
  id        String   @id @default(uuid())
  name      String
  category  String?
  subject   String?
  body      String
  ownerId   String?  // null = partage avec tous
  owner     User?    @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
}

// =================== ASSETS (materiel / licences clients) ===================

enum AssetType {
  HARDWARE
  LICENSE
  SOFTWARE
  DOMAIN
  CERTIFICATE
  M365_LICENSE
  OTHER
}

enum AssetStatus {
  ACTIVE
  INACTIVE
  EXPIRED
  RETIRED
}

model Asset {
  id             String        @id @default(uuid())
  name           String
  type           AssetType     @default(HARDWARE)
  status         AssetStatus   @default(ACTIVE)
  identifier     String?       // numero de serie, cle de licence, FQDN, etc.
  vendor         String?       // Microsoft, HP, Lenovo, etc.
  model          String?
  acquiredAt     DateTime?
  warrantyUntil  DateTime?
  expiresAt      DateTime?     // pour licences/domains/certs
  // EOSL : date de fin de support du vendor (HP/Cisco/Microsoft annonce
  // formellement la fin de support — apres, plus de patches secu, NIS2 NOK).
  // Different de warrantyUntil (qui est la fin de garantie commerciale).
  supportEndDate DateTime?
  costHt         Decimal?      @db.Decimal(10, 2)
  // Budget estime pour le remplacement (devis vendor, RDV technique, etc.).
  // Utilise pour planifier le CAPEX client annuel.
  replacementBudgetHt Decimal? @db.Decimal(10, 2)
  // Contact SAV / revendeur (numero / email / portail). Texte libre.
  vendorContact  String?
  notes          String?
  // Auto-monitoring SSL / WHOIS (DOMAIN, CERTIFICATE)
  // expiresAt est rempli automatiquement, lastMonitoredAt = horodatage du dernier check.
  // monitoringEnabled = false desactive le cron pour cet asset.
  lastMonitoredAt DateTime?
  monitoringEnabled Boolean   @default(true)
  monitoringError String?    // dernier message d'erreur si check echoue

  companyId      String
  company        Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contractId     String?
  contract       Contract?     @relation(fields: [contractId], references: [id], onDelete: SetNull)

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([companyId])
  @@index([contractId])
  @@index([type])
  @@index([expiresAt])
}

// =================== UPTIME MONITORING ===================

// Surveillance HTTP/HTTPS d'un site ou endpoint client. Le cron uptime
// frappe l'URL toutes les `intervalMinutes` minutes et stocke un check
// dans UptimeCheck. Apres N echecs consecutifs, un UptimeIncident est
// ouvert + notification (in-app + email) au proprietaire.
model UptimeMonitor {
  id              String           @id @default(uuid())
  name            String           // libelle ("Site vitrine ACME")
  url             String           // ex: https://www.acme.fr/
  method          String           @default("GET")
  expectedStatus  Int              @default(200)
  intervalMinutes Int              @default(5)
  enabled         Boolean          @default(true)
  // Expose ce monitor sur la page /status publique (anonymisee, sans URL ni nom client).
  // Defaut false : tous les monitors clients sont prives. A activer manuellement pour
  // les services internes MDO (CRM, site vitrine, etc.) qu'on veut montrer publiquement.
  isPublic        Boolean          @default(false)

  companyId       String?
  company         Company?         @relation(fields: [companyId], references: [id], onDelete: SetNull)

  // Cache du dernier etat pour les listings rapides
  lastCheckedAt   DateTime?
  lastStatus      String?          // "UP" | "DOWN" | null
  lastHttpCode    Int?
  lastResponseMs  Int?
  lastError       String?
  consecutiveFailures Int          @default(0)
  alertSentAt     DateTime?        // pour eviter spam

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  checks          UptimeCheck[]
  incidents       UptimeIncident[]

  @@index([companyId])
  @@index([enabled])
}

model UptimeCheck {
  id          String         @id @default(uuid())
  monitorId   String
  monitor     UptimeMonitor  @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  checkedAt   DateTime       @default(now())
  isUp        Boolean
  httpCode    Int?
  responseMs  Int?
  error       String?

  @@index([monitorId, checkedAt])
}

model UptimeIncident {
  id              String         @id @default(uuid())
  monitorId       String
  monitor         UptimeMonitor  @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  startedAt       DateTime
  endedAt         DateTime?
  durationSeconds Int?
  reason          String?        // dernier message d'erreur observe

  @@index([monitorId, startedAt])
}

// =================== DOCUMENTATION CLIENT (KB) ===================

model DocPage {
  id          String   @id @default(uuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  title       String
  category    String?  // ex: Reseau, Acces, Procedures, Onboarding
  body        String   // markdown
  authorId    String?
  author      User?    @relation("DocPageAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  versions    DocPageVersion[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyId])
  @@index([category])
}

// Snapshot d'une page de doc avant chaque modification.
// Cree automatiquement au moment du PATCH pour permettre rollback.
model DocPageVersion {
  id          String   @id @default(uuid())
  pageId      String
  page        DocPage  @relation(fields: [pageId], references: [id], onDelete: Cascade)
  title       String
  category    String?
  body        String
  authorId    String?  // qui a fait la modif qui a cree cette version (= valeur AVANT modif)
  reason      String?  // commentaire optionnel ("avant refonte reseau")
  createdAt   DateTime @default(now())

  @@index([pageId, createdAt])
}

// Coffre-fort de secrets cote client (mots de passe, cles d'acces).
// La valeur est stockee chiffree avec une cle maitre derive de SECRETS_MASTER_KEY.
model SecretEntry {
  id          String   @id @default(uuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  label       String   // "Acces admin firewall", "Compte M365 admin", etc.
  username    String?
  // Les champs ciphered* contiennent { iv, authTag, data } encodes en base64
  cipheredValue String  // mot de passe / cle chiffre
  // Secret TOTP (base32) chiffre, pour generer les codes 2FA partages
  // (compte admin firewall, M365 break-glass, etc.). Optionnel.
  cipheredTotp  String?
  url         String?
  category    String?
  notes       String?
  createdById String?
  createdBy   User?    @relation("SecretEntryCreator", fields: [createdById], references: [id], onDelete: SetNull)
  lastAccessedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyId])
}

// =================== FACTURATION ===================

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  OVERDUE
  CANCELLED
}

// Origine de la facture : interne au CRM, ou miroir d'un outil externe (PDP)
enum BillingProviderKind {
  INTERNAL  // Facture generee dans le CRM (mode legacy / compatibilite)
  // @deprecated 2026-05 : Sellsy retire du stack MDO. Valeur conservee pour
  // preserver l'integrite des Invoice historiques deja crees avec ce provider.
  SELLSY
  QONTO     // Source de verite : Qonto Factures (PDP)
}

model Invoice {
  id             String        @id @default(uuid())
  number         String        @unique  // ex : 2026-04-0001
  status         InvoiceStatus @default(DRAFT)
  issueDate      DateTime      @default(now())
  dueDate        DateTime
  paidAt         DateTime?
  totalHt        Decimal       @db.Decimal(12, 2)
  totalTtc       Decimal       @db.Decimal(12, 2)
  vatRate        Decimal       @default(20) @db.Decimal(5, 2)
  notes          String?

  // Source / synchronisation avec un outil de facturation externe
  provider         BillingProviderKind @default(INTERNAL)
  externalId       String?      // ID dans Sellsy / Qonto
  externalUrl      String?      // URL profonde vers la facture dans l'outil source
  externalPdfUrl   String?      // URL PDF directe (si disponible)
  externalSyncedAt DateTime?

  companyId      String
  company        Company       @relation(fields: [companyId], references: [id], onDelete: Restrict)
  contractId     String?
  contract       Contract?     @relation(fields: [contractId], references: [id], onDelete: SetNull)

  lines          InvoiceLine[]
  bankTransactions BankTransaction[]

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([provider, externalId])
  @@index([companyId])
  @@index([contractId])
  @@index([status])
  @@index([issueDate])
  @@index([provider])
}

model InvoiceLine {
  id          String   @id @default(uuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  quantity    Decimal  @db.Decimal(10, 2)
  unitPriceHt Decimal  @db.Decimal(10, 2)
  totalHt     Decimal  @db.Decimal(12, 2)

  @@index([invoiceId])
}

// =================== TRESORERIE / BANQUE (Qonto) ===================

enum BankSource {
  QONTO
  MANUAL
  OTHER
}

enum BankTransactionSide {
  CREDIT
  DEBIT
}

// Mouvements bancaires importes depuis Qonto, conserves en cache pour
// rapprochement avec les factures (par client) et vue tresorerie.
model BankTransaction {
  id             String              @id @default(uuid())
  source         BankSource          @default(QONTO)
  externalId     String              @unique  // qonto transaction id
  bookedAt       DateTime
  side           BankTransactionSide
  amount         Decimal             @db.Decimal(14, 2)  // montant absolu
  currency       String              @default("EUR")
  label          String              // libelle nettoye
  rawLabel       String?             // libelle brut (debug)
  counterparty   String?             // nom IBAN/contrepartie
  reference      String?             // reference virement
  status         String?             // completed / pending (Qonto)

  companyId      String?             // rapproche a un client
  company        Company?            @relation(fields: [companyId], references: [id], onDelete: SetNull)
  invoiceId      String?             // rapproche a une facture
  invoice        Invoice?            @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  importedAt     DateTime            @default(now())

  @@index([bookedAt])
  @@index([companyId])
  @@index([invoiceId])
  @@index([status])
}

// =================== DOCUMENTATION CLIENT - IT GLUE LIKE ===================

// Sites physiques d'un client (multi-site).
// Permet de localiser materiel, contacts, interventions par site.
model Location {
  id          String   @id @default(uuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name        String   // ex : "Siege Toulouse", "Agence Montpellier"
  isPrimary   Boolean  @default(false)
  address     String?
  postalCode  String?
  city        String?
  country     String?  @default("France")
  phone       String?
  notes       String?
  // Coordonnees GPS pour cartographie / planning intervention
  latitude    Float?
  longitude   Float?

  networks    Network[]
  flexibleAssets FlexibleAsset[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyId])
}

enum NetworkKind {
  LAN
  WAN
  WIFI
  VPN
  DMZ
  GUEST
  OTHER
}

// Reseaux d'un client : plages IP, VLANs, sous-reseaux, gateway, DNS.
// Sert de doc reseau structuree (au lieu de markdown a la main).
model Network {
  id          String      @id @default(uuid())
  companyId   String
  company     Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  locationId  String?
  location    Location?   @relation(fields: [locationId], references: [id], onDelete: SetNull)

  name        String      // "LAN bureaux", "WIFI guest", "VPN site to site"
  kind        NetworkKind @default(LAN)
  cidr        String?     // ex : "10.0.0.0/24"
  vlanId      Int?
  gateway     String?
  dnsServers  String?     // separes par virgule
  dhcpStart   String?
  dhcpEnd     String?
  description String?

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([companyId])
  @@index([locationId])
}

// ----- Flexible Assets (cle de voute IT Glue-like) -----
// Permet de definir des templates de documentation custom par MSP :
// "Tenant M365", "Firewall Fortinet", "Backup Veeam", "ISP", "AD config", etc.
// Chaque template definit un schema de champs, et chaque instance stocke les valeurs.

enum FlexibleFieldType {
  TEXT
  TEXTAREA
  NUMBER
  BOOLEAN
  DATE
  URL
  EMAIL
  PASSWORD       // valeur stockee chiffree dans FlexibleAsset.secretValues
  IP_ADDRESS
  SELECT
  MULTISELECT
  REFERENCE_COMPANY
  REFERENCE_CONTACT
  REFERENCE_ASSET
}

// Definition d'un type d'asset flexible (template).
// Cree par l'admin, reutilise sur tous les clients.
model FlexibleAssetType {
  id          String   @id @default(uuid())
  name        String   @unique
  icon        String?  // nom Lucide icon (ex: "Server", "Cloud", "Shield")
  color       String?  // couleur hex pour affichage
  description String?
  fields      FlexibleAssetField[]
  assets      FlexibleAsset[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Definition d'un champ d'un type flexible.
model FlexibleAssetField {
  id           String              @id @default(uuid())
  typeId       String
  type         FlexibleAssetType   @relation(fields: [typeId], references: [id], onDelete: Cascade)
  key          String              // ex : "tenant_id", "contract_end"
  label        String              // ex : "Identifiant tenant"
  fieldType    FlexibleFieldType   @default(TEXT)
  required     Boolean             @default(false)
  position     Int                 @default(0)
  // Pour SELECT / MULTISELECT : options separees par "|"
  options      String?
  // Pour les references : on stocke "Company" / "Contact" / "Asset" ici si besoin
  refEntity    String?
  // Aide affichee dans le formulaire
  helpText     String?

  @@unique([typeId, key])
  @@index([typeId])
}

// Instance d'un type flexible pour un client donne.
// Les valeurs des champs sont stockees en JSON ; les champs PASSWORD
// dans secretValues (cipheredValues separes par cle).
model FlexibleAsset {
  id          String              @id @default(uuid())
  typeId      String
  type        FlexibleAssetType   @relation(fields: [typeId], references: [id], onDelete: Restrict)
  companyId   String
  company     Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  locationId  String?
  location    Location?           @relation(fields: [locationId], references: [id], onDelete: SetNull)

  name        String              // libelle de l'instance, ex : "Tenant M365 prod"
  // Valeurs en clair (texte/nombre/date/bool/etc.) ; key = field.key
  values      Json                @default("{}")
  // Valeurs chiffrees (champs PASSWORD) ; key = field.key, value = base64 cipher
  secretValues Json               @default("{}")

  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([companyId])
  @@index([typeId])
  @@index([locationId])
}

// Quick Notes : post-it epingles par societe pour les infos critiques rapides.
// "Acces VPN -> exception sur l'IP X.X.X.X", "Contact urgence : 06...", etc.
model QuickNote {
  id          String   @id @default(uuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  content     String
  color       String?  // jaune, rouge, vert (couleur post-it)
  pinned      Boolean  @default(true)
  authorId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyId])
}

// =================== RUNBOOKS / PROCEDURES ===================

enum RunbookCategory {
  ONBOARDING
  AUDIT
  PATCHING
  INCIDENT
  OFFBOARDING
  AUTRE
}

// Modele de procedure reutilisable (catalogue partage entre tous les clients).
// Ex : "Onboarding nouveau client", "Audit trimestriel", "Patch management mensuel".
model Runbook {
  id          String           @id @default(uuid())
  name        String
  category    RunbookCategory  @default(AUTRE)
  description String?
  steps       RunbookStep[]
  runs        RunbookRun[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

// Etape d'un runbook template.
model RunbookStep {
  id           String   @id @default(uuid())
  runbookId    String
  runbook      Runbook  @relation(fields: [runbookId], references: [id], onDelete: Cascade)
  position     Int      @default(0)
  title        String
  details      String?  // markdown : explication, lien, snippet, etc.
  estimatedMin Int?     // duree estimee en minutes
  required     Boolean  @default(true)

  @@index([runbookId, position])
}

// Instance executee d'un runbook pour un client donne.
// Conserve la check-list cochee + qui a fait quoi quand.
model RunbookRun {
  id           String   @id @default(uuid())
  runbookId    String
  runbook      Runbook  @relation(fields: [runbookId], references: [id], onDelete: Restrict)
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  startedById  String?
  startedAt    DateTime @default(now())
  completedAt  DateTime?
  // Etat des cases : { stepId: { done: bool, doneById: string, doneAt: iso, note: string } }
  state        Json     @default("{}")

  @@index([companyId])
  @@index([runbookId])
}

// Relation polymorphe entre items du CRM (Asset, FlexibleAsset, DocPage,
// SecretEntry, Network, Location, Contract, Contact, Ticket, ...).
// Stockes par paire ordonnee (sourceEntity/sourceId, targetEntity/targetId).
model ItemLink {
  id            String   @id @default(uuid())
  sourceEntity  String   // ex : "FlexibleAsset"
  sourceId      String
  targetEntity  String   // ex : "SecretEntry"
  targetId      String
  label         String?  // libelle libre, ex : "credentials admin"
  createdById   String?
  createdAt     DateTime @default(now())

  @@unique([sourceEntity, sourceId, targetEntity, targetId])
  @@index([sourceEntity, sourceId])
  @@index([targetEntity, targetId])
}

// =================== 2FA ===================

model UserMfa {
  userId       String   @id
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  secret       String   // base32 TOTP secret (chiffre avec SECRETS_MASTER_KEY)
  enabled      Boolean  @default(false)
  recoveryCodes String  // JSON liste de codes hashes
  enabledAt    DateTime?
  createdAt    DateTime @default(now())
}

// =================== PORTAIL CLIENT (sous-domaine client.mdoservices.fr) ===================
//
// Authentification distincte des utilisateurs internes (modele User). Un contact
// chez un client peut se connecter via un magic link envoye sur son email pro,
// a condition que le domaine email corresponde a une societe enregistree.
// Acces strictement scope a `companyId` (impossible de voir une autre societe).

model ClientPortalUser {
  id            String   @id @default(uuid())
  email         String   @unique
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  // Lien optionnel vers le Contact CRM correspondant (rempli automatiquement si
  // un Contact existe deja avec cet email pour cette societe).
  contactId     String?
  contact       Contact? @relation("ContactPortalUser", fields: [contactId], references: [id], onDelete: SetNull)
  firstName     String?
  lastName      String?
  isActive      Boolean  @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  magicLinks    ClientPortalMagicLink[]
  sessions      ClientPortalSession[]

  @@index([companyId])
}

model ClientPortalMagicLink {
  id            String   @id @default(uuid())
  userId        String
  user          ClientPortalUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  // On stocke un hash SHA256 du token clair. Le token clair n'apparait que dans
  // l'email envoye au client — une fuite de la BDD ne donne pas acces aux liens.
  tokenHash     String   @unique
  expiresAt     DateTime
  usedAt        DateTime?
  ip            String?
  userAgent     String?
  createdAt     DateTime @default(now())

  @@index([expiresAt])
}

model ClientPortalSession {
  id            String   @id @default(uuid())
  userId        String
  user          ClientPortalUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  token         String   @unique  // opaque, 32 bytes hex
  expiresAt     DateTime
  revokedAt     DateTime?
  ip            String?
  userAgent     String?
  lastUsedAt    DateTime @default(now())
  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

// =================== MICROSOFT 365 / GRAPH API ===================
//
// Pour chaque societe cliente, MDO peut connecter le tenant M365 via OAuth
// admin consent (app multi-tenant enregistree sur le tenant MDO). Une fois
// consenti, MDO peut interroger periodiquement Graph API pour synchroniser
// la liste des utilisateurs, leurs licences, leur statut MFA et les alertes
// de securite.

model M365Tenant {
  id              String   @id @default(uuid())
  companyId       String   @unique
  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  // GUID Entra ID du tenant client (immuable)
  tenantId        String   @unique
  tenantDomain    String?  // ex: acme.onmicrosoft.com
  consentedAt     DateTime?
  consentedBy     String?  // email/nom de l'admin client qui a fait le consent
  lastSyncAt      DateTime?
  lastSyncStatus  String?  // 'OK' | 'FAILED' | 'PARTIAL'
  lastSyncError   String?
  isActive        Boolean  @default(true)
  // Microsoft Secure Score (https://learn.microsoft.com/en-us/graph/api/securescore-get).
  // Indicateur Microsoft officiel de la posture securite du tenant : couvre MFA,
  // conditional access, Defender, partage externe, etc. — beaucoup plus complet
  // que la seule couverture MFA. Necessite la permission SecurityEvents.Read.All
  // ET un tenant avec les licences appropriees (E3/E5/Business Premium). Si non
  // disponible, ces champs restent null et le CRM retombe sur le MFA pur.
  secureScore         Float?    // currentScore brut (echelle Microsoft, generalement 0-1000+)
  secureScoreMax      Float?    // maxScore atteignable pour ce tenant (varie selon licences)
  secureScorePercent  Float?    // currentScore / maxScore * 100 (cache pour filtrer/agreger sans recalculer)
  secureScoreSyncedAt DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  users           M365User[]
  licenses        M365License[]
  alerts          M365SecurityAlert[]
  managedDevices  PatchManagedDevice[]

  @@index([companyId])
}

model M365User {
  id             String      @id @default(uuid())
  m365TenantId   String
  m365Tenant     M365Tenant  @relation(fields: [m365TenantId], references: [id], onDelete: Cascade)
  graphId        String      // ID Graph immuable
  upn            String      // user principal name (ex: john@acme.onmicrosoft.com)
  displayName    String?
  jobTitle       String?
  department     String?
  accountEnabled Boolean     @default(true)
  // null = inconnu (API premium non disponible ou pas encore syncho). True/false sinon.
  mfaEnabled     Boolean?
  lastSignInAt   DateTime?
  // skuPartNumbers attribues (ex: ["ENTERPRISEPACK","EMS"])
  licenseSkus    Json
  syncedAt       DateTime    @default(now())

  @@unique([m365TenantId, graphId])
  @@index([m365TenantId])
  @@index([accountEnabled])
  @@index([mfaEnabled])
}

model M365License {
  id              String      @id @default(uuid())
  m365TenantId    String
  m365Tenant      M365Tenant  @relation(fields: [m365TenantId], references: [id], onDelete: Cascade)
  skuId           String      // GUID
  skuPartNumber   String      // ex: ENTERPRISEPACK
  name            String?     // libelle humain (mapping local : ENTERPRISEPACK -> Office 365 E3)
  totalUnits      Int
  consumedUnits   Int
  syncedAt        DateTime    @default(now())

  @@unique([m365TenantId, skuId])
  @@index([m365TenantId])
}

model M365SecurityAlert {
  id              String      @id @default(uuid())
  m365TenantId    String
  m365Tenant      M365Tenant  @relation(fields: [m365TenantId], references: [id], onDelete: Cascade)
  alertId         String      // ID Graph de l'alerte
  severity        String      // low / medium / high / informational
  status          String      // newAlert / inProgress / resolved
  title           String
  description     String?
  category        String?
  createdDateTime DateTime
  syncedAt        DateTime    @default(now())

  @@unique([m365TenantId, alertId])
  @@index([m365TenantId, severity])
  @@index([status])
}

// =================== NPS / SATISFACTION POST-TICKET ===================
//
// Envoi automatique d'un mini-questionnaire au contact du ticket quand le statut
// passe a RESOLVED. Le client clique sur le lien, note de 0 a 10 + commentaire
// optionnel. Stockage dans TicketSatisfaction, agrege ensuite pour le NPS global.

model TicketSatisfaction {
  id              String    @id @default(uuid())
  // Un ticket = au plus une demande NPS active (unique).
  ticketId        String    @unique
  ticket          Ticket    @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  // Token cryptosecure pour la page publique de notation. Indexe pour lookup rapide.
  token           String    @unique
  tokenExpiresAt  DateTime
  sentTo          String
  sentAt          DateTime
  // Reponse du client. Null tant que pas encore soumise.
  score           Int?      // 0 - 10
  comment         String?
  submittedAt     DateTime?
  // IP/UA tronques au moment de la soumission, pour detection de fraude basique.
  submittedIp     String?
  submittedUa     String?

  @@index([sentAt])
  @@index([submittedAt])
  @@index([score])
}

// =================== CLIENT MONTHLY REPORTS ===================
//
// Rapport mensuel par client : agrege tickets resolus, interventions, uptime,
// surveillance certificats/domaines + inventaire assets sur une periode donnee.
// Genere soit manuellement depuis la fiche societe, soit automatiquement le 1er
// de chaque mois via un cron (ClientReportsService.runMonthlyCron).
//
// Le PDF est stocke sur disque (UPLOADS_DIR/client-reports/) et accede via un
// token cryptosecure 32 bytes hex (URL : /api/reports/download/:token). Le
// token a une duree de vie de 30 jours pour ne pas creer de fuites permanentes.

enum ClientReportStatus {
  GENERATED   // PDF cree, pas encore envoye
  SENT        // Email envoye au contact principal
  DOWNLOADED  // Au moins un telechargement effectue via le lien
  EXPIRED     // Token expire (information seulement, le PDF reste accessible en admin)
}

model ClientReport {
  id              String              @id @default(uuid())
  companyId       String
  company         Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  // Periode couverte : mois entier en general (1er → dernier jour).
  periodStart     DateTime
  periodEnd       DateTime
  // Chemin relatif au UPLOADS_DIR (ex. client-reports/2026/05/abcd.pdf)
  pdfPath         String
  // Taille en octets, utile pour les UI et la suppression.
  pdfSize         Int
  // Token cryptosecure pour le download public. Indexe car cle de lookup.
  accessToken     String              @unique
  tokenExpiresAt  DateTime
  status          ClientReportStatus  @default(GENERATED)
  // Stats agregees stockees en JSON pour affichage rapide cote admin sans
  // regenerer le PDF (ex. "12 tickets resolus, 4 interventions, uptime 99.8 %").
  summary         Json
  // Trace de l'envoi
  sentTo          String?
  sentAt          DateTime?
  // Trace des telechargements (count + dernier)
  downloadCount   Int                 @default(0)
  lastDownloadAt  DateTime?
  // Auteur de la generation (null si auto via cron)
  generatedById   String?
  createdAt       DateTime            @default(now())

  @@index([companyId, periodStart])
  @@index([accessToken])
  @@index([tokenExpiresAt])
  @@index([status])
}

// =================== WORKFLOW RULES ENGINE ===================
//
// Moteur de regles simples "quand <trigger> alors <action>". Permet de codifier
// les reflexes operationnels recurrents (alerter sur contrats expirant, creer
// une task sur ticket overdue, etc.) avant l'arrivee d'un collaborateur — qui
// n'aura pas la memoire historique de Mathieu.
//
// Architecture : cron quotidien evalue toutes les regles actives. Pour chaque
// regle, le trigger produit une liste d'entites cible. Pour chaque entite, on
// verifie WorkflowExecution (unique sur ruleId+entityType+entityId) pour
// dedupliquer — une regle ne tire qu'UNE fois par entite, pas une fois par jour.

enum WorkflowTrigger {
  CONTRACT_EXPIRING    // contracts ACTIVE avec endDate dans le futur <= triggerParams.daysBefore
  TICKET_OVERDUE       // tickets non resolus avec dueDate < now
  ASSET_EXPIRING       // assets ACTIVE avec expiresAt dans le futur <= triggerParams.daysBefore
  INVOICE_OVERDUE      // factures non payees avec dueDate < now - triggerParams.daysOverdue
}

enum WorkflowAction {
  CREATE_TASK          // Task creee avec titre/priorite/assignee depuis actionParams
  CREATE_NOTIFICATION  // Notification in-app push vers actionParams.targetRole (ADMIN/MANAGER/OWNER)
}

model WorkflowRule {
  id              String           @id @default(uuid())
  name            String           // libelle admin ("Alerte contrats expirant 60 jours")
  description     String?
  trigger         WorkflowTrigger
  // Parametres du trigger (JSON cle/valeur) :
  //  - CONTRACT_EXPIRING : { daysBefore: number }
  //  - ASSET_EXPIRING : { daysBefore: number }
  //  - INVOICE_OVERDUE : { daysOverdue: number }
  //  - TICKET_OVERDUE : {} (pas de param, dueDate suffit)
  triggerParams   Json             @default("{}")
  action          WorkflowAction
  // Parametres de l'action (JSON cle/valeur) :
  //  - CREATE_TASK : { titleTemplate: string, priority?: TaskPriority,
  //                    dueDateOffsetDays?: number, assigneeId?: string }
  //  - CREATE_NOTIFICATION : { title: string, body?: string,
  //                            targetRole?: 'ADMIN'|'MANAGER'|'OWNER' }
  // titleTemplate supporte des placeholders {entityField} substitues a l'execution
  // (ex. "Preparer renouvellement {reference}" pour CONTRACT_EXPIRING).
  actionParams    Json             @default("{}")
  isActive        Boolean          @default(true)
  // Audit / observabilite
  lastEvaluatedAt DateTime?
  lastFiredAt     DateTime?
  firedCount      Int              @default(0)
  // Assignee par defaut si l'action est CREATE_TASK et qu'aucun assigneeId
  // n'est specifie dans actionParams. Permet de dire "assigne par defaut a moi".
  assigneeId      String?
  assignee        User?            @relation("WorkflowRuleAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  createdById     String
  createdBy       User             @relation("WorkflowRuleCreator", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  executions      WorkflowExecution[]

  @@index([isActive, trigger])
}

model WorkflowExecution {
  id          String        @id @default(uuid())
  ruleId      String
  rule        WorkflowRule  @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  // Identite de l'entite cible (Contract, Ticket, Asset, Invoice). On ne fait
  // PAS de FK Prisma vers chaque type — c'est polymorphe. Si l'entite est
  // supprimee plus tard, l'execution reste pour audit (entityId orphelin = OK).
  entityType  String
  entityId    String
  firedAt     DateTime      @default(now())
  // Resultat textuel pour audit ("TASK_CREATED:<taskId>" ou "NOTIFICATION_SENT:N").
  // Permet de retracer ce que la regle a fait sans charger d'autres tables.
  result      String?

  // Cle de dedup : une regle ne tire qu'UNE fois par entite (sauf reset manuel
  // de l'execution). Si tu veux qu'une regle re-tire periodiquement, supprime
  // l'execution ou ajoute une logique "fireEveryDays" dans triggerParams plus tard.
  @@unique([ruleId, entityType, entityId])
  @@index([firedAt])
  @@index([entityType, entityId])
}

// =================== QUOTES (devis commerciaux) ===================
//
// Etape commerciale entre Opportunity (negociation) et Contract (signe).
// Permet de generer un PDF presentable, de l'envoyer au client, de tracer son
// acceptation puis de le convertir en 1-clic en Contract (toutes les valeurs
// sont reportees, plus le rattachement convertedToContractId).
//
// Workflow : DRAFT -> SENT -> (ACCEPTED|REJECTED|EXPIRED). Un devis ACCEPTED
// peut etre converti en Contract ; apres conversion, status reste ACCEPTED
// (le devis n'est jamais "consume", il reste comme trace commerciale).

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

model Quote {
  id            String      @id @default(uuid())
  reference     String      @unique
  title         String
  status        QuoteStatus @default(DRAFT)
  // Validite : dateLimite d'acceptation cote client. Au-dela, status passe a
  // EXPIRED automatiquement par cron (job journalier dans QuotesService).
  validUntil    DateTime
  issueDate     DateTime    @default(now())
  vatRate       Decimal     @default(20) @db.Decimal(5, 2)
  notes         String?
  // Conditions affichees en bas du PDF (delais paiement, RIB, mentions legales)
  // Editable par devis ; valeur par defaut depuis Settings('quote.defaultTerms').
  terms         String?

  // Totaux denormalises (recalcules a chaque update lignes). Eviter les requetes
  // d'agregation a chaque liste de devis.
  subtotalHt    Decimal     @default(0) @db.Decimal(12, 2)
  vatAmount     Decimal     @default(0) @db.Decimal(12, 2)
  totalTtc      Decimal     @default(0) @db.Decimal(12, 2)

  // Tracage workflow
  sentAt        DateTime?
  acceptedAt    DateTime?
  rejectedAt    DateTime?
  rejectionReason String?

  companyId     String
  company       Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contactId     String?
  contact       Contact?    @relation(fields: [contactId], references: [id], onDelete: SetNull)
  opportunityId String?
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  ownerId       String?
  owner         User?       @relation("QuoteOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  // Si converti en contrat : reference vers le Contract cree. Permet "1 quote
  // -> 1 contract max", on ne peut pas convertir 2 fois le meme devis.
  convertedToContractId String?  @unique
  convertedToContract   Contract? @relation("ContractFromQuote", fields: [convertedToContractId], references: [id], onDelete: SetNull)
  convertedAt           DateTime?

  lines         QuoteLine[]

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([companyId])
  @@index([status])
  @@index([validUntil])
  @@index([status, validUntil])
}

model QuoteLine {
  id          String   @id @default(uuid())
  quoteId     String
  quote       Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  position    Int      @default(0)
  description String
  quantity    Decimal  @default(1) @db.Decimal(10, 2)
  unitPriceHt Decimal  @db.Decimal(10, 2)
  // Remise % appliquee a cette ligne uniquement (0..100). Calcule :
  // lineTotalHt = quantity * unitPriceHt * (1 - discountPct/100).
  discountPct Decimal  @default(0) @db.Decimal(5, 2)
  // Pre-calcule pour la liste des devis et pour le PDF (evite recalcul cote front).
  lineTotalHt Decimal  @db.Decimal(12, 2)

  // Lien optionnel vers le catalogue produits (pour suivi marges revente).
  // Si renseigne, le purchasePriceHt du Product est utilise pour calculer
  // la marge reelle de cette ligne (cf module profitability + dashboard exec).
  productId   String?
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  // Snapshot du prix d'achat AU MOMENT du devis (le Product peut evoluer apres,
  // on veut que la marge historique reste calculee correctement).
  purchasePriceHtSnapshot Decimal? @db.Decimal(10, 2)

  @@index([quoteId])
  @@index([productId])
}

// =================== CATALOGUE PRODUITS ===================
//
// Catalogue des produits/services revendus par MDO : licences M365, Bitdefender,
// Veeam Cloud Connect, materiel HPE, prestations specifiques, etc.
//
// Sert a :
//  - Pre-remplir les lignes de devis (selecteur produit avec prix conseille)
//  - Calculer les MARGES reelles (sellingPrice - purchasePrice) par ligne
//  - Stats globales : top vendors, marge totale par categorie
//  - Suivi engagements vendor (renouvellement licence cote MDO chez le vendor)

enum ProductType {
  LICENSE          // licence logicielle (M365, BD GravityZone, ...)
  HARDWARE         // materiel revendu (NAS, switch, firewall, ...)
  SERVICE          // prestation MDO (audit, formation, install, ...)
  RECURRING        // abonnement (cloud, monitoring, supervision, ...)
}

model Product {
  id              String      @id @default(uuid())
  // Code interne court et unique (ex. "M365_BP", "BD_GZ_10", "VEEAM_O365_10").
  // Affiche dans les listes de selection.
  code            String      @unique
  name            String
  description     String?
  vendor          String?     // 'Microsoft', 'Bitdefender', 'Veeam', 'HPE', ...
  type            ProductType @default(SERVICE)
  // Periodicite par defaut pour les RECURRING. Affiche dans le selecteur
  // pour clarifier "9.10 €/utilisateur/mois" vs "275 € HT one-shot".
  recurringPeriod String?     // 'mensuel', 'annuel', null pour ONE_OFF
  // Prix d'achat HT (cout MDO chez le vendor). Sert au calcul de marge.
  purchasePriceHt Decimal?    @db.Decimal(10, 2)
  // Prix de vente conseille HT (proposition par defaut, le commercial peut
  // l'overrider sur le devis).
  sellingPriceHt  Decimal?    @db.Decimal(10, 2)
  // Devise de reference (sera EUR pour 99 % des cas). Stocker pour eviter
  // les surprises plus tard si tu importes un cataloque vendor en USD.
  currency        String      @default("EUR")
  vatRate         Decimal     @default(20) @db.Decimal(5, 2)
  // Categorie libre pour grouper dans l'UI (Securite, Sauvegarde, M365, ...).
  category        String?
  // Tag obsolete : on garde le produit en BDD pour l'historique des devis,
  // mais il n'apparait plus dans les selecteurs.
  isActive        Boolean     @default(true)

  quoteLines      QuoteLine[]
  quoteTemplateLines QuoteTemplateLine[]

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([isActive])
  @@index([vendor])
  @@index([type])
}

// =================== QUOTE TEMPLATES ===================
//
// Modeles pre-remplis de devis (offres standards MDO + add-ons cyber, audit,
// formation...). Cliquer sur "Charger template X" sur la page nouveau devis
// remplit toutes les lignes en une fois, avec snapshot productId si lie au
// catalogue. Le commercial peut ensuite ajuster qte / prix / lignes.

model QuoteTemplate {
  id              String                @id @default(uuid())
  name            String                // "Pack MDO Pro 10 utilisateurs", "Audit cyber initial"
  description     String?
  // Categorie pour grouper dans le selecteur ("Offres standards", "Add-ons", "Audits"...)
  category        String?
  // Offre cible si applicable — si renseignee, le template est pre-suggere
  // dans le selecteur quand l'opportunite/devis est lie a cette offre.
  offer           ContractOffer?
  // Conditions / mentions par defaut pre-remplies sur le devis
  defaultTerms    String?
  isActive        Boolean               @default(true)

  lines           QuoteTemplateLine[]

  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@index([isActive, offer])
}

model QuoteTemplateLine {
  id              String          @id @default(uuid())
  templateId      String
  template        QuoteTemplate   @relation(fields: [templateId], references: [id], onDelete: Cascade)
  position        Int             @default(0)
  description     String
  // Quantite par defaut. Le commercial peut overrider sur le devis genere.
  quantity        Decimal         @default(1) @db.Decimal(10, 2)
  // Prix unitaire HT par defaut (peut etre overrride si productId est defini —
  // le sellingPriceHt du Product prend le dessus a la generation).
  unitPriceHt     Decimal         @db.Decimal(10, 2)
  discountPct     Decimal         @default(0) @db.Decimal(5, 2)
  // Lien vers le catalogue produits — si renseigne, le snapshot purchasePrice
  // est capture lors de la generation du devis (cf module products).
  productId       String?
  product         Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([templateId])
}

// =================== CUSTOMER SUCCESS REVIEWS (QBR) ===================
//
// Quarterly Business Reviews — revues clients programmees automatiquement
// pour les CUSTOMER actifs. Cron mensuel : si la derniere review d'un client
// remonte a plus de N jours (Settings customerSuccess.frequencyDays, defaut 90),
// programme une nouvelle review pour J+7 et notifie l'owner.
//
// Anti-churn proactif : force le contact regulier avec le client meme quand
// tout va bien (sinon on n'appelle que quand il y a des problemes).

enum CustomerSuccessReviewStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

model CustomerSuccessReview {
  id            String                       @id @default(uuid())
  companyId     String
  company       Company                      @relation(fields: [companyId], references: [id], onDelete: Cascade)

  scheduledAt   DateTime                     // date prevue
  status        CustomerSuccessReviewStatus  @default(SCHEDULED)
  heldAt        DateTime?                    // date effective de tenue
  // Owner = generalement le commercial / customer success manager du client
  ownerId       String?
  owner         User?                        @relation("CustomerSuccessReviewOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  // Resume de la reunion (notes saisies apres tenue)
  notes         String?
  // Items d'agenda pre-generes par le service (Health alerts, contrats a
  // renouveler, opportunites, etc.) — JSON pour flexibilite.
  agendaItems   Json?
  // Score satisfaction client a l'issue de la reunion (0-10, optionnel)
  satisfactionScore Int?
  // Tracking : a-t-on declenche une notif J-7 a l'owner ?
  reminderSentAt DateTime?

  createdAt     DateTime                     @default(now())
  updatedAt     DateTime                     @updatedAt

  @@index([companyId])
  @@index([scheduledAt, status])
  @@index([ownerId, status])
}

// =================== DRIP CAMPAIGNS (email sequences) ===================
//
// Sequences d'emails programmes pour transformer les leads tiedes :
// J+0 bienvenue, J+3 cas d'usage, J+7 RDV, etc.
//
// Architecture :
//   - DripCampaign : modele de sequence
//   - DripCampaignStep : etape (subject + body + dayOffset)
//   - DripEnrollment : instance pour un destinataire (lead/contact)
//   - DripSentEmail : trace d'envoi par step
//
// Cron quotidien : pour chaque enrollment RUNNING, envoie le step matchant
// (enrolledAt + dayOffset == aujourd'hui), avance au suivant.

enum DripCampaignTrigger {
  MANUAL              // enrollement manuel via UI
  COMPANY_CREATED_AS_LEAD  // auto a la creation d'une Company avec status=LEAD
}

enum DripEnrollmentStatus {
  RUNNING
  COMPLETED
  PAUSED
  UNSUBSCRIBED
}

model DripCampaign {
  id            String                @id @default(uuid())
  name          String
  description   String?
  trigger       DripCampaignTrigger   @default(MANUAL)
  isActive      Boolean               @default(true)

  steps         DripCampaignStep[]
  enrollments   DripEnrollment[]

  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  @@index([isActive, trigger])
}

model DripCampaignStep {
  id            String            @id @default(uuid())
  campaignId    String
  campaign      DripCampaign      @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  position      Int               @default(0)
  // Decalage en jours depuis l'enrollment. Step a J+0 part le jour meme.
  dayOffset     Int               @default(0)
  subject       String
  // Corps HTML (avec placeholders {firstName}, {companyName} substitues a l'envoi)
  bodyHtml      String

  sentEmails    DripSentEmail[]

  @@index([campaignId])
}

model DripEnrollment {
  id              String                  @id @default(uuid())
  campaignId      String
  campaign        DripCampaign            @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  // Destinataire identifie par email (peut etre un Contact, ou une adresse
  // externe importee). Pas de FK dure pour rester souple.
  recipientEmail  String
  recipientName   String?
  // Si lie a un Contact existant (contexte commercial)
  contactId       String?
  contact         Contact?                @relation(fields: [contactId], references: [id], onDelete: SetNull)
  // Company associee (utile pour les substitutions {companyName} et le filtre UI)
  companyId       String?
  company         Company?                @relation(fields: [companyId], references: [id], onDelete: SetNull)

  status          DripEnrollmentStatus    @default(RUNNING)
  enrolledAt      DateTime                @default(now())
  completedAt     DateTime?
  // Index du prochain step a envoyer (0 = etape 1). Avance apres chaque envoi.
  nextStepIndex   Int                     @default(0)

  sentEmails      DripSentEmail[]

  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  // Un meme email ne peut etre enroll qu'une fois par campagne (sauf
  // re-enrollement manuel apres COMPLETED — supprimer puis recreer).
  @@unique([campaignId, recipientEmail])
  @@index([status])
  @@index([contactId])
  @@index([companyId])
}

model DripSentEmail {
  id              String           @id @default(uuid())
  enrollmentId    String
  enrollment      DripEnrollment   @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  stepId          String
  step            DripCampaignStep @relation(fields: [stepId], references: [id], onDelete: Cascade)
  sentAt          DateTime         @default(now())
  // Status d'envoi (succes/echec) — texte libre pour stocker le message
  // d'erreur SMTP eventuel.
  sendStatus      String           @default("SENT")
  sendError       String?

  @@unique([enrollmentId, stepId])
  @@index([enrollmentId])
  @@index([sentAt])
}

// =================== PATCH MANAGEMENT (devices Intune) ===================
//
// Synchronisation des appareils MDM depuis chaque tenant M365 (Intune).
// Permet d'identifier les devices non patches / non conformes / non chiffres
// par client, vendable comme prestation cyber distincte.
//
// Cron quotidien sync GET /deviceManagement/managedDevices via Graph API.
// Permission requise : DeviceManagementManagedDevices.Read.All (admin
// consent cote client + ajout dans le scope app M365).

model PatchManagedDevice {
  id                String      @id @default(uuid())
  m365TenantId      String
  m365Tenant        M365Tenant  @relation(fields: [m365TenantId], references: [id], onDelete: Cascade)
  // Identifiant Intune (managedDevices.id)
  externalId        String

  deviceName        String
  // OS string brute ("Windows", "iOS", "macOS", ...)
  operatingSystem   String?
  osVersion         String?
  // 'compliant' | 'noncompliant' | 'unknown' | 'inGracePeriod' | 'configManager' | 'error'
  complianceState   String?
  // Type de management ('mdm' = Intune, 'eas' = ActiveSync seul, ...)
  managementAgent   String?
  // Date du dernier sync de l'appareil avec Intune
  lastSyncDateTime  DateTime?
  enrolledDateTime  DateTime?
  isEncrypted       Boolean     @default(false)
  isSupervised      Boolean     @default(false)
  userPrincipalName String?
  serialNumber      String?
  manufacturer      String?
  model             String?
  // Date de notre dernier sync avec Graph
  syncedAt          DateTime    @default(now())

  @@unique([m365TenantId, externalId])
  @@index([m365TenantId, complianceState])
  @@index([userPrincipalName])
}

// =================== BACKUP VERIFICATION ===================
//
// Comble un trou critique du metier MSP : detecter quand un backup client
// a echoue silencieusement.
//
// Architecture deliberement souple :
//   - BackupJob : declaration d'un job a surveiller
//   - BackupRun : execution individuelle (status + timestamps + taille)
//
// Ingestion (3 modes possibles) :
//   1. POST /backup-jobs/:id/runs (manuel ou webhook signe avec ingestSecret)
//   2. Import CSV via UI (export Veeam ou Datto)
//   3. (Futur) parsing email IMAP des rapports Veeam quotidiens
//
// Cron quotidien : alerte les jobs sans SUCCESS dans la fenetre attendue.

enum BackupSourceType {
  M365            // Backup M365 mailbox/SharePoint/OneDrive
  VM              // VM hyperviseur (Veeam, Vinchin, ...)
  FILES           // Fichiers/serveurs (NAS, FileServer)
  DATABASE        // SQL/Postgres/Mongo
  ENDPOINT        // Postes utilisateurs (Datto, ...)
  OTHER
}

enum BackupRunStatus {
  RUNNING
  SUCCESS
  WARNING       // succes partiel (ex. 95 % des items, vendor genere un warning)
  FAILED
  SKIPPED
}

model BackupJob {
  id                String           @id @default(uuid())
  companyId         String
  company           Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name              String           // libelle interne
  vendor            String?          // 'Veeam', 'Acronis', 'Datto', 'Vinchin', '365 Backup'...
  sourceType        BackupSourceType @default(OTHER)
  // Identifiant chez le vendor (job id Veeam, plan id Acronis, ...)
  sourceIdentifier  String?
  // Frequence attendue : si pas de SUCCESS dans cette fenetre, on alerte.
  // Defaut 26h (laisse 2h de marge sur un backup quotidien).
  expectedFrequencyHours Int         @default(26)
  // Secret pour authentifier les ingestions webhook. Genere a la creation,
  // affiche UNE FOIS dans l'UI puis masque (hash stocke).
  ingestSecret      String?
  isActive          Boolean          @default(true)
  // Compteurs miroirs (recalcules apres chaque ingestion)
  lastRunStatus     BackupRunStatus?
  lastRunAt         DateTime?
  lastSuccessAt     DateTime?
  lastSuccessSizeBytes BigInt?

  runs              BackupRun[]

  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([companyId])
  @@index([isActive, lastSuccessAt])
}

model BackupRun {
  id              String           @id @default(uuid())
  jobId           String
  job             BackupJob        @relation(fields: [jobId], references: [id], onDelete: Cascade)
  status          BackupRunStatus
  startedAt       DateTime
  endedAt         DateTime?
  durationSec     Int?
  // Taille du backup en octets (BigInt — peut depasser 4 Go)
  sizeBytes       BigInt?
  itemsCount      Int?             // nombre d'items / fichiers / mailbox sauvegardes
  // Message du vendor (texte libre, errors, warnings)
  message         String?
  // Identifiant de l'execution chez le vendor (run id) — dedup webhooks
  externalRunId   String?
  rawPayload      Json?            // payload brut webhook pour audit/debug

  createdAt       DateTime         @default(now())

  @@unique([jobId, externalRunId])
  @@index([jobId, startedAt])
  @@index([status])
}

// =================== ONBOARDING CLIENT ===================
//
// Standardise le processus d'integration d'un nouveau client : creer compte
// M365, deployer EDR, ajouter au monitoring, programmer kick-off, etc.
//
// Architecture a deux niveaux :
//   - OnboardingTemplate : modele reutilisable, generalement 1 par offre
//     (MDO_ESSENTIEL, MDO_PRO, MDO_SOUVERAIN, ou globale).
//   - OnboardingRun : instance pour 1 contrat. Auto-declenchee a la signature
//     du contrat (status passe a ACTIVE + signedAt) si un template matche
//     l'offre, OU manuellement via bouton "Demarrer onboarding".

enum OnboardingRunStatus {
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum OnboardingStepStatus {
  PENDING
  IN_PROGRESS
  DONE
  SKIPPED
}

model OnboardingTemplate {
  id          String              @id @default(uuid())
  name        String
  description String?
  // Si null, le template est global (s'applique a toutes les offres). Sinon
  // il ne sera auto-declenche que pour les contrats de cette offre.
  offer       ContractOffer?
  isActive    Boolean             @default(true)

  steps       OnboardingTemplateStep[]
  runs        OnboardingRun[]

  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([offer, isActive])
}

model OnboardingTemplateStep {
  id              String              @id @default(uuid())
  templateId      String
  template        OnboardingTemplate  @relation(fields: [templateId], references: [id], onDelete: Cascade)
  position        Int                 @default(0)
  title           String
  description     String?
  // Decalage en jours par rapport au demarrage du run pour calculer dueDate
  // de la step. Permet "Etape 1 le jour J, etape 7 a J+30".
  dueDateOffsetDays Int               @default(0)
  // Role par defaut a qui la step est assignee (resolu cote service en
  // prenant le premier user actif du role).
  assigneeRole    Role?

  @@index([templateId])
}

model OnboardingRun {
  id           String                @id @default(uuid())
  templateId   String
  template     OnboardingTemplate    @relation(fields: [templateId], references: [id], onDelete: Restrict)
  // Contrat declencheur. Si null, c'est un onboarding manuel (sans contrat
  // associe — rare mais possible).
  contractId   String?               @unique
  contract     Contract?             @relation(fields: [contractId], references: [id], onDelete: SetNull)
  // Societe cible (denormalise pour eviter la jointure quand on liste les
  // onboardings par client cote UI).
  companyId    String
  company      Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)

  status       OnboardingRunStatus   @default(IN_PROGRESS)
  startedAt    DateTime              @default(now())
  completedAt  DateTime?

  // Compteurs miroirs (recalcules a chaque update step) : evite agregation
  // pour la liste et permet de derive un % d'avancement.
  totalSteps    Int                  @default(0)
  doneSteps     Int                  @default(0)
  skippedSteps  Int                  @default(0)

  steps        OnboardingRunStep[]

  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  @@index([companyId])
  @@index([status])
}

model OnboardingRunStep {
  id          String                @id @default(uuid())
  runId       String
  run         OnboardingRun         @relation(fields: [runId], references: [id], onDelete: Cascade)
  position    Int                   @default(0)
  title       String
  description String?
  status      OnboardingStepStatus  @default(PENDING)
  dueDate     DateTime?
  assigneeId  String?
  assignee    User?                 @relation("OnboardingStepAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  doneAt      DateTime?
  doneById    String?
  doneBy      User?                 @relation("OnboardingStepCloser", fields: [doneById], references: [id], onDelete: SetNull)
  notes       String?

  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@index([runId])
  @@index([assigneeId, status])
}

// =================== KNOWLEDGE BASE ===================
//
// Capture les resolutions recurrentes pour gagner du temps. Trois portees :
//   INTERNAL : interne MDO (procedures, troubleshooting techniciens)
//   CLIENT   : specifique a un client (ses creds, son env, ses incidents
//              recurrents) — visible MDO + portail client si publie
//   GLOBAL   : visible a tous les clients via portail (FAQ "Comment activer
//              MFA M365 ?", "Reinitialiser mot de passe Outlook"...)
//
// Workflow : un tech resoud un ticket complexe -> "Transformer en article KB"
// (bouton sur ticket) -> pre-rempli avec sujet + resolution + tags. Le tech
// edite et publie. Les futurs tickets similaires affichent les KB matchant.

enum KbScope {
  INTERNAL
  CLIENT
  GLOBAL
}

model KbArticle {
  id              String   @id @default(uuid())
  title           String
  // Slug URL-friendly auto-genere a la creation. Unique pour l'integration
  // future avec un router /kb/[slug] cote portail.
  slug            String   @unique
  // Markdown — rendu cote frontend (pas de HTML pour eviter XSS sur portail).
  content         String
  // Resume court (1-2 phrases) pour les listes / cartes de recherche.
  excerpt         String?

  scope           KbScope  @default(INTERNAL)
  // Si scope=CLIENT, l'article ne concerne que cette societe (visible
  // techniciens MDO + portail de cette societe uniquement).
  companyId       String?
  company         Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  category        String?  // libre : "Email", "Backup", "MFA", "Reseau"...
  tags            String[] @default([])

  // Workflow publication : DRAFT -> PUBLISHED. Seuls les PUBLISHED sont
  // visibles cote portail client. Les INTERNAL DRAFT restent visibles MDO.
  isPublished     Boolean  @default(false)
  publishedAt     DateTime?
  // Date de derniere relecture/maj (pour signaler les KB obsoletes via
  // badge "revue depuis > 12 mois").
  lastReviewedAt  DateTime?

  // Compteurs (incrementes par les endpoints de lecture)
  viewCount       Int      @default(0)
  helpfulCount    Int      @default(0)

  // Si l'article a ete genere depuis un ticket (bouton "Convert to KB")
  sourceTicketId  String?

  authorId        String
  author          User     @relation("KbArticleAuthor", fields: [authorId], references: [id], onDelete: Restrict)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([scope, isPublished])
  @@index([companyId])
  @@index([category])
  @@index([authorId])
}

// =================== EMAIL SECURITY MONITORING ===================
//
// Verifie SPF / DMARC / DKIM pour chaque domaine client. Sert de plus-value
// cyber et complete le module surveillance (qui ne fait que SSL + WHOIS).
//
// Score 0-100 :
//   SPF present              : 25 pts
//   SPF politique stricte    : +10 (-all)
//   DMARC present            : 30 pts
//   DMARC policy=reject      : +15
//   DMARC policy=quarantine  : +10
//   DMARC policy=none        : +5
//   DMARC rua (reporting)    : +5
//   DKIM (selector trouve)   : +15
//
// Cron quotidien re-verifie tous les domaines (asset type=DOMAIN actifs).

model EmailSecurityCheck {
  id            String   @id @default(uuid())
  // Domaine au format racine ("mdoservices.fr"). Pas de FK dure vers Asset
  // car on peut re-verifier un domaine meme si l'asset est supprime entre-temps
  // — utile pour conserver l'historique.
  domain        String   @unique
  // Si rattachable a une societe (via lookup Asset), on denormalise pour
  // pouvoir filtrer par client cote UI.
  companyId     String?
  company       Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  // ----- SPF -----
  spfRecord     String?  // valeur brute du record TXT v=spf1
  spfPolicy     String?  // 'pass' (-all), 'softfail' (~all), 'neutral' (?all), 'all' (+all)

  // ----- DMARC -----
  dmarcRecord   String?  // valeur brute du record TXT v=DMARC1
  dmarcPolicy   String?  // 'reject', 'quarantine', 'none'
  dmarcRua      String?  // adresse(s) reporting agregee
  dmarcSubdomainPolicy String?

  // ----- DKIM -----
  dkimSelector  String?  // selector trouve (default, selector1, google, ...)
  dkimRecord    String?
  dkimPresent   Boolean  @default(false)

  scorePct      Int      @default(0)
  // Erreur eventuelle (DNS timeout, NXDOMAIN, etc.)
  error         String?

  lastCheckedAt DateTime @default(now())
  createdAt     DateTime @default(now())

  @@index([companyId])
  @@index([scorePct])
}

// =================== PHISHING SIMULATION ===================
//
// Tracker les campagnes de phishing simule (formation utilisateurs).
// Plateforme externe (KnowBe4, GoPhish, Microsoft Attack Simulator, ...).
//
// Workflow : MDO importe les resultats CSV apres campagne. Le CRM stocke
// les stats par campagne + resultat individuel par destinataire pour
// identifier les utilisateurs qui ratent + cibler la formation.

enum PhishingVendor {
  KNOWBE4
  GOPHISH
  M365_ATTACK_SIM
  CUSTOM
}

enum PhishingCampaignStatus {
  DRAFT
  RUNNING
  COMPLETED
  CANCELLED
}

model PhishingCampaign {
  id              String                  @id @default(uuid())
  name            String                  // libelle interne ("Phishing Q2 2026 Banque")
  vendor          PhishingVendor          @default(GOPHISH)
  externalId      String?                 // id externe chez le vendor

  companyId       String
  company         Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)

  status          PhishingCampaignStatus  @default(DRAFT)
  sentAt          DateTime?               // date d'envoi des emails
  completedAt     DateTime?               // date de cloture (analyse terminee)

  // Compteurs (recalcules depuis les results a chaque import CSV)
  totalRecipients   Int                   @default(0)
  openedCount       Int                   @default(0)
  clickedCount      Int                   @default(0)
  reportedCount     Int                   @default(0)  // signale comme phishing par le user
  dataEnteredCount  Int                   @default(0)  // a saisi des creds (le pire)

  templateName    String?                 // nom du modele d'email phishing utilise
  notes           String?

  results         PhishingResult[]

  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  @@index([companyId])
  @@index([status])
}

model PhishingResult {
  id              String              @id @default(uuid())
  campaignId      String
  campaign        PhishingCampaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  userEmail       String              // identifiant unique dans la campagne
  userName        String?

  // Etats de progression : opened > clicked > dataEntered (escalade)
  opened          Boolean             @default(false)
  clicked         Boolean             @default(false)
  reportedAsPhish Boolean             @default(false)
  dataEntered     Boolean             @default(false)

  openedAt        DateTime?
  clickedAt       DateTime?
  reportedAt      DateTime?
  dataEnteredAt   DateTime?

  createdAt       DateTime            @default(now())

  @@unique([campaignId, userEmail])
  @@index([campaignId])
  @@index([userEmail])
}

// =================== SIGNATURE ELECTRONIQUE ===================
//
// Polymorphe : signe un Quote OU un Contract (entityType + entityId, pas de FK
// dure car deux types possibles). Quand le provider notifie via webhook, on
// retrouve le SignatureRequest via providerSubmissionId puis on met a jour
// status + signedAt + on retropropage signedAt sur l'entite cible (Quote.acceptedAt
// si quote, Contract.signedAt si contract).
//
// Providers supportes : DocuSeal (self-hosted, souverain — defaut) et Yousign
// (cloud FR, eIDAS Avance). Selection via Settings('signature.provider').

enum SignatureProvider {
  DOCUSEAL
  YOUSIGN
}

enum SignatureStatus {
  PENDING       // creee, signataire pas encore venu
  VIEWED        // signataire a ouvert le document
  SIGNED        // signature finalisee
  DECLINED      // signataire a refuse
  EXPIRED       // delai de signature depasse
  CANCELLED     // annulee cote MDO avant signature
}

model SignatureRequest {
  id                String            @id @default(uuid())
  // Polymorphe (pas de FK Prisma — l'entite est dereferencable a la main).
  // Utiliser type discriminant ('Quote' | 'Contract') + id pour retrouver l'entite.
  entityType        String            // 'Quote' | 'Contract'
  entityId          String
  provider          SignatureProvider @default(DOCUSEAL)
  status            SignatureStatus   @default(PENDING)

  // Identifiants externes du provider (varient selon le provider) :
  //  - DocuSeal : submission id (numerique, on stocke en string)
  //  - Yousign : signature_request id (UUID)
  providerSubmissionId String?        @unique
  // URL ouvrable par le signataire (envoyee par email)
  providerSignerUrl    String?
  // URL du document signe une fois finalise (CDN provider ou stockage local)
  signedDocumentUrl    String?

  // Signataire principal (un seul pour le MVP — la plupart de nos contrats
  // ont un seul signataire client). Si besoin ulterieur de multi-signataires,
  // ajouter une table SignatureSigner.
  signerName        String
  signerEmail       String
  signerPhone       String?            // pour OTP SMS si provider supporte

  requestedAt       DateTime          @default(now())
  viewedAt          DateTime?
  signedAt          DateTime?
  declinedAt        DateTime?
  declineReason     String?
  expiresAt         DateTime?

  // Audit trail : on garde tous les webhooks recus en JSON pour pouvoir
  // re-jouer / debugger / prouver en cas de litige.
  webhookEvents     Json[]            @default([])

  // Companies/Contact pour faciliter le filtre cote UI (denormalise depuis
  // l'entite cible — petit cout d'ecriture, gros gain en lecture).
  companyId         String?
  company           Company?          @relation(fields: [companyId], references: [id], onDelete: SetNull)

  createdById       String
  createdBy         User              @relation("SignatureRequestCreator", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([entityType, entityId])
  @@index([status])
  @@index([companyId])
}

// =================== CALL LOGS (Telephonie / VoIP) ===================
//
// Journalise les appels entrants et sortants relatifs a un contact / une societe.
// Alimente :
//  - manuellement via click-to-call (POST /calls/click)
//  - automatiquement via webhook provider VoIP (POST /calls/webhook/:provider)
//
// Si le numero correspond a un Contact existant (matching normalise E.164),
// le CallLog est rattache automatiquement a ce contact + sa societe.

enum CallDirection {
  INBOUND
  OUTBOUND
}

enum CallStatus {
  RINGING
  ANSWERED
  MISSED
  BUSY
  FAILED
  COMPLETED
}

model CallLog {
  id            String        @id @default(uuid())
  direction     CallDirection
  status        CallStatus    @default(RINGING)
  // Numeros normalises E.164 (+33...) si possible. On garde les versions
  // brutes recues du provider dans rawPayload pour debug.
  fromNumber    String
  toNumber      String

  startedAt     DateTime      @default(now())
  answeredAt    DateTime?
  endedAt       DateTime?
  durationSec   Int?

  // Resolution automatique
  contactId     String?
  contact       Contact?      @relation(fields: [contactId], references: [id], onDelete: SetNull)
  companyId     String?
  company       Company?      @relation(fields: [companyId], references: [id], onDelete: SetNull)
  // Utilisateur MDO concerne (passeur d'appel sortant ou destinataire d'entrant).
  userId        String?
  user          User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Optionnels (selon provider)
  recordingUrl  String?
  notes         String?
  // Provider technique (FREE_PRO|TEL_URI|MANUAL) pour debug.
  provider      String        @default("MANUAL")
  // Identifiant externe (call_id, sip_id) pour deduplication des webhooks.
  externalId    String?       @unique
  // Payload brut pour audit / debug.
  rawPayload    Json?

  createdAt     DateTime      @default(now())

  @@index([contactId])
  @@index([companyId])
  @@index([userId])
  @@index([startedAt])
  @@index([direction, status])
}

// =================== AI USAGE (suivi cout API Claude) ===================
//
// Trace chaque invocation IA pour pouvoir surveiller la facture Anthropic.
// On stocke les tokens et le cout estime ; pas le prompt complet pour ne pas
// gonfler la BDD (les prompts contiennent souvent du contenu client). Si
// besoin de debug, activer ai.logFullPrompts en Settings (off par defaut).

enum AiCapability {
  TICKET_TRIAGE
  TICKET_DRAFT
  CLIENT_SUMMARY
  GENERIC
}

model AiUsage {
  id            String        @id @default(uuid())
  capability    AiCapability
  model         String        // 'claude-sonnet-4-6', etc.
  // Tokens : reportes par l'API. cacheReadTokens et cacheCreationTokens si
  // prompt caching active (les cache reads coutent 10x moins cher).
  inputTokens   Int           @default(0)
  outputTokens  Int           @default(0)
  cacheReadTokens     Int     @default(0)
  cacheCreationTokens Int     @default(0)
  // Cout estime en USD (calcule cote service avec tarifs publies, peut diverger
  // legerement de la facture reelle Anthropic).
  costUsd       Decimal?      @db.Decimal(10, 6)
  durationMs    Int?
  // Entite cible si applicable (ticket id, company id, ...). Polymorphe.
  entityType    String?
  entityId      String?
  // Erreur eventuelle (timeout, refus politique, etc.)
  errorMessage  String?
  userId        String?
  user          User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt     DateTime      @default(now())

  @@index([capability])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([userId])
}

// =================== COMPLIANCE (NIS2 / ISO 27001 / HDS / ...) ===================
//
// Modele a deux niveaux :
//
//   1) Templates (ComplianceFramework + ComplianceControl) : referentiel
//      reutilisable. NIS2 = 10 mesures, ISO 27001 Annexe A = 93 controles.
//      Editable depuis l'UI admin.
//
//   2) Instances (ComplianceAssessment + ComplianceControlAssessment) : audit
//      d'UN client contre UN framework. Chaque controle a son statut individuel
//      avec preuves + notes + echeance. Le score global de l'assessment est
//      recalcule a chaque update (denormalise pour la liste clients).

enum ComplianceControlStatus {
  NOT_STARTED       // pas encore evalue
  IN_PROGRESS       // en cours de mise en conformite
  COMPLIANT         // conforme — preuve a l'appui
  NON_COMPLIANT     // ecart identifie
  NOT_APPLICABLE    // hors scope client
}

enum ComplianceCriticality {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model ComplianceFramework {
  id          String   @id @default(uuid())
  // Code court unique (NIS2, ISO27001, HDS, RGPD_TPE, ...)
  code        String   @unique
  name        String
  description String?
  // Version du referentiel (utile quand NIS2 sera mis a jour)
  version     String   @default("1.0")
  // Si false, le framework est cache dans les listes (deprecated mais on garde
  // les assessments existants).
  isActive    Boolean  @default(true)

  controls    ComplianceControl[]
  assessments ComplianceAssessment[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
}

model ComplianceControl {
  id           String                @id @default(uuid())
  frameworkId  String
  framework    ComplianceFramework   @relation(fields: [frameworkId], references: [id], onDelete: Cascade)
  // Code dans le referentiel (ex. "NIS2-1", "ISO-A.5.1", "HDS-3.2")
  code         String
  title        String
  description  String?
  // Categorie metier (Gouvernance, Technique, Personnel, Continuite, ...)
  category     String?
  criticality  ComplianceCriticality @default(MEDIUM)
  // Ordre d'affichage dans la checklist
  position     Int                   @default(0)

  controlAssessments ComplianceControlAssessment[]

  @@unique([frameworkId, code])
  @@index([frameworkId])
}

model ComplianceAssessment {
  id            String              @id @default(uuid())
  companyId     String
  company       Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  frameworkId   String
  framework     ComplianceFramework @relation(fields: [frameworkId], references: [id], onDelete: Restrict)
  // Score 0-100 denormalise (recalcule par le service a chaque mise a jour
  // de controle). Permet d'afficher le score dans la liste des clients sans
  // joindre + agreger les controles.
  scorePct      Int                 @default(0)
  // Compteurs miroirs pour eviter les agregations (utiles pour les badges UI).
  compliantCount       Int          @default(0)
  nonCompliantCount    Int          @default(0)
  inProgressCount      Int          @default(0)
  notStartedCount      Int          @default(0)
  notApplicableCount   Int          @default(0)
  totalControls        Int          @default(0)
  // Owner cote MDO (le RSSI / consultant en charge)
  ownerId       String?
  owner         User?               @relation("ComplianceOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  // Echeance globale (date de revision suivante)
  nextReviewAt  DateTime?
  notes         String?

  controlAssessments ComplianceControlAssessment[]

  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  // Une societe ne peut avoir qu'UN audit actif par framework. Si besoin de
  // re-auditer, on remplace celui-la (l'historique est trace via Activity).
  @@unique([companyId, frameworkId])
  @@index([companyId])
  @@index([frameworkId])
}

model ComplianceControlAssessment {
  id            String                  @id @default(uuid())
  assessmentId  String
  assessment    ComplianceAssessment    @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  controlId     String
  control       ComplianceControl       @relation(fields: [controlId], references: [id], onDelete: Cascade)
  status        ComplianceControlStatus @default(NOT_STARTED)
  // Preuves : texte libre (chemin doc IT Glue, nom de procedure, etc.) +
  // optionnellement URL externe (Sharepoint / GED). Pas d'upload pour le MVP
  // mais les attachments existants peuvent y etre lies via ItemLink si besoin.
  evidence      String?
  evidenceUrl   String?
  notes         String?
  dueDate       DateTime?
  lastReviewedAt DateTime?
  reviewedById  String?
  reviewedBy    User?                   @relation("ControlReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  @@unique([assessmentId, controlId])
  @@index([assessmentId])
  @@index([status])
}

// =================== WEB PUSH SUBSCRIPTIONS ===================
//
// Permet aux techniciens d'etre notifies dans leur navigateur (Chrome/Edge/
// Firefox/Safari) sur les evenements critiques meme onglet ferme : nouveau
// ticket urgent, intervention dans 1h, alerte uptime DOWN.
//
// Le user peut s'abonner depuis plusieurs appareils — un user peut avoir
// N subscriptions (une par device + browser). Le endpoint sert de cle
// d'unicite (Push API : un endpoint par triplet device+browser+origine).
//
// VAPID keys partagees pour tout le service, stockees dans Settings.

// =================== API KEYS (API publique externe) ===================
//
// Permet a des integrations tierces (Zapier, n8n, scripts client, dashboard
// externe...) d'acceder en lecture/ecriture limitee a leur scope.
//
// Deux types de cles :
//  - GLOBAL : creee par un ADMIN MDO, acces a tout (utilisation interne ou
//    integrations puissantes type backup script).
//  - CLIENT : scope = une societe specifique. Le client recoit la cle, ne
//    peut acceder qu'a SES tickets, contrats, factures, assets.
//
// La cle complete n'est montree qu'UNE FOIS a la creation. On stocke
// uniquement le SHA-256 + un prefix lisible pour l'identification UI.
//
// Usage : Authorization: Bearer mdo_live_<32_random_chars>

enum ApiKeyScope {
  GLOBAL_READ
  GLOBAL_WRITE
  CLIENT_READ
  CLIENT_WRITE
}

model ApiKey {
  id          String      @id @default(uuid())
  name        String      // libelle pour identification ("Zapier prod", "Backup script")
  scope       ApiKeyScope @default(CLIENT_READ)
  // Hash SHA-256 de la cle complete. La cle elle-meme n'est jamais stockee.
  keyHash     String      @unique
  // Prefix lisible (premiers 12 chars de la cle) pour l'UI : "mdo_live_a3f"
  prefix      String      @db.VarChar(20)
  // Si scope = CLIENT_*, la cle est limitee a cette societe.
  companyId   String?
  company     Company?    @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Audit
  createdById String
  createdBy   User        @relation("ApiKeyCreator", fields: [createdById], references: [id], onDelete: Restrict)
  lastUsedAt  DateTime?
  lastUsedIp  String?
  usageCount  Int         @default(0)
  expiresAt   DateTime?
  revokedAt   DateTime?

  createdAt   DateTime    @default(now())

  @@index([companyId])
  @@index([prefix])
  @@index([keyHash])
}

model PushSubscription {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // URL de push specifique au browser/device. Format long, contient un ID
  // opaque cote service push (FCM/Mozilla/etc.).
  endpoint    String   @unique
  // Cles necessaires au chiffrement E2E du payload (Push API specs).
  p256dh      String
  auth        String
  // Etiquette informelle pour l'UI sessions (browser + OS sniffe au moment
  // de l'inscription).
  userAgent   String?
  // Compteur d'echecs de push. Au-dela de 5 echecs (typiquement 410 Gone =
  // l'utilisateur a desinstalle l'app), on supprime la subscription.
  failureCount Int     @default(0)
  lastUsedAt  DateTime?
  createdAt   DateTime @default(now())

  @@index([userId])
}
