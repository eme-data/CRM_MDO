// CRM MDO Services - Prisma schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =================== USERS AND TEAMS ===================

enum Role {
  ADMIN
  MANAGER
  SALES
  READONLY
}

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  passwordHash    String
  firstName       String
  lastName        String
  role            Role      @default(SALES)
  isActive        Boolean   @default(true)
  lastLoginAt     DateTime?
  // Signature email pour les replies tickets sortants (texte brut, format libre)
  signature       String?
  // Token opaque pour l'export iCal authentifie (les clients calendrier ne
  // supportent pas Bearer). NULL tant que l'utilisateur n'a pas active la
  // fonctionnalite ; revoquable via /users/me/ical/regenerate.
  icalToken       String?   @unique
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  teamId          String?
  team            Team?     @relation(fields: [teamId], references: [id], onDelete: SetNull)

  ownedCompanies     Company[]      @relation("CompanyOwner")
  ownedContacts      Contact[]      @relation("ContactOwner")
  ownedOpportunities Opportunity[]  @relation("OpportunityOwner")
  ownedContracts     Contract[]     @relation("ContractOwner")
  assignedTasks      Task[]         @relation("TaskAssignee")
  createdTasks       Task[]         @relation("TaskCreator")
  assignedTickets    Ticket[]       @relation("TicketAssignee")
  createdTickets     Ticket[]       @relation("TicketCreator")
  ticketMessages     TicketMessage[]
  uploadedAttachments Attachment[]  @relation("AttachmentUploader")
  timeEntries        TimeEntry[]
  invoicedTimeEntries TimeEntry[]   @relation("TimeEntryInvoicer")
  notifications      Notification[]
  responseTemplates  ResponseTemplate[]
  authoredDocPages   DocPage[]      @relation("DocPageAuthor")
  createdSecrets     SecretEntry[]  @relation("SecretEntryCreator")
  mfa                UserMfa?
  notes              Note[]
  activities         Activity[]
  refreshTokens      RefreshToken[]
  interventions      Intervention[] @relation("InterventionTechnician")
  recurringTemplatesCreated  RecurringTaskTemplate[] @relation("RecurringTemplateCreator")
  recurringTemplatesAssigned RecurringTaskTemplate[] @relation("RecurringTemplateAssignee")
  workflowRulesCreated   WorkflowRule[]  @relation("WorkflowRuleCreator")
  workflowRulesAssigned  WorkflowRule[]  @relation("WorkflowRuleAssignee")
  ownedQuotes            Quote[]         @relation("QuoteOwner")
  signatureRequests      SignatureRequest[] @relation("SignatureRequestCreator")

  @@index([teamId])
}

model Team {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]
}

model RefreshToken {
  id          String    @id @default(uuid())
  token       String    @unique
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Metadata utilisee par l'UI sessions/devices (pas de fingerprinting fort,
  // juste une etiquette informelle pour aider l'utilisateur a reconnaitre la session).
  userAgent   String?
  ip          String?
  lastUsedAt  DateTime?
  expiresAt   DateTime
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId])
}

// =================== COMPANIES AND CONTACTS ===================

enum CompanyStatus {
  LEAD
  PROSPECT
  CUSTOMER
  INACTIVE
}

enum CompanySector {
  PME
  TPE
  COLLECTIVITE
  SANTE
  INDUSTRIE
  EDUCATION
  ASSOCIATION
  AUTRE
}

model Company {
  id          String        @id @default(uuid())
  name        String
  // Identifiants legaux (sources : Pappers / INSEE Sirene)
  siret       String?       @unique
  siren       String?       @unique
  apeCode     String?       // ex: "62.02A"
  apeLabel    String?       // ex: "Conseil en systemes et logiciels informatiques"
  legalForm   String?       // ex: "SARL", "SAS", "SASU"
  creationDate DateTime?    // date de creation entreprise
  capitalSocial Decimal?    @db.Decimal(14, 2)
  lastSyncedAt DateTime?    // derniere synchro avec annuaire externe
  // Donnees CRM
  sector      CompanySector @default(PME)
  status      CompanyStatus @default(LEAD)
  employees   Int?
  website     String?
  phone       String?
  email       String?
  address     String?
  postalCode  String?
  city        String?
  country     String?       @default("France")
  notes       String?

  ownerId     String?
  owner       User?         @relation("CompanyOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  // Identifiants externes (outils de facturation tiers)
  // @deprecated 2026-05 : Sellsy retire du stack MDO. Champ conserve pour ne
  // pas perdre les references historiques des companies deja synchronisees
  // dans Sellsy. Plus aucune ecriture cote code.
  sellsyId    String?       @unique
  qontoClientId String?     @unique  // ID du client dans Qonto Factures

  contacts       Contact[]
  opportunities  Opportunity[]
  contracts      Contract[]
  tasks          Task[]
  notesRel       Note[]
  interventions  Intervention[]
  tickets        Ticket[]
  assets         Asset[]
  docPages       DocPage[]
  secrets        SecretEntry[]
  invoices       Invoice[]
  bankTransactions BankTransaction[]
  locations      Location[]
  networks       Network[]
  flexibleAssets FlexibleAsset[]
  quickNotes     QuickNote[]
  runbookRuns    RunbookRun[]
  uptimeMonitors UptimeMonitor[]
  clientReports  ClientReport[]
  timeEntries    TimeEntry[]
  portalUsers    ClientPortalUser[]
  m365Tenant     M365Tenant?
  recurringTemplates RecurringTaskTemplate[]
  quotes         Quote[]
  signatureRequests SignatureRequest[]

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([ownerId])
  @@index([status])
  @@index([name])
  @@index([siren])
}

model Contact {
  id          String   @id @default(uuid())
  firstName   String
  lastName    String
  email       String?
  phone       String?
  mobile      String?
  position    String?
  isPrimary   Boolean  @default(false)
  notes       String?

  companyId   String?
  company     Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  ownerId     String?
  owner       User?    @relation("ContactOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  tasks       Task[]
  notesRel    Note[]
  tickets     Ticket[]
  portalUsers ClientPortalUser[] @relation("ContactPortalUser")
  quotes      Quote[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyId])
  @@index([ownerId])
  @@index([email])
}

// =================== OPPORTUNITIES ===================

enum OpportunityStage {
  QUALIFICATION
  PROPOSITION
  NEGOCIATION
  GAGNE
  PERDU
}

model Opportunity {
  id                String           @id @default(uuid())
  title             String
  stage             OpportunityStage @default(QUALIFICATION)
  amountHt          Decimal          @default(0) @db.Decimal(12, 2)
  probability       Int              @default(50)
  expectedCloseDate DateTime?
  closedAt          DateTime?
  lostReason        String?
  description       String?

  companyId         String
  company           Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)

  ownerId           String?
  owner             User?            @relation("OpportunityOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  contracts         Contract[]
  tasks             Task[]
  notesRel          Note[]
  quotes            Quote[]

  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([companyId])
  @@index([ownerId])
  @@index([stage])
}

// =================== CONTRACTS (core business need) ===================

enum ContractOffer {
  MDO_ESSENTIEL
  MDO_PRO
  MDO_SOUVERAIN
  CUSTOM
}

enum ContractStatus {
  DRAFT
  ACTIVE
  SUSPENDED
  EXPIRED
  TERMINATED
  RENEWED
}

enum BillingPeriod {
  MONTHLY
  QUARTERLY
  YEARLY
}

model Contract {
  id                 String         @id @default(uuid())
  reference          String         @unique
  title              String
  offer              ContractOffer  @default(MDO_ESSENTIEL)
  status             ContractStatus @default(DRAFT)

  startDate          DateTime
  endDate            DateTime
  signedAt           DateTime?

  engagementMonths   Int            @default(12)
  billingPeriod      BillingPeriod  @default(MONTHLY)
  unitPriceHt        Decimal        @db.Decimal(10, 2)
  quantity           Int            @default(1)
  monthlyAmountHt    Decimal        @db.Decimal(12, 2)
  setupFeeHt         Decimal?       @db.Decimal(10, 2)
  vatRate            Decimal        @default(20) @db.Decimal(5, 2)

  autoRenew          Boolean        @default(true)
  noticePeriodMonths Int            @default(3)
  terminatedAt       DateTime?
  terminationReason  String?

  companyId          String
  company            Company        @relation(fields: [companyId], references: [id], onDelete: Restrict)

  opportunityId      String?
  opportunity        Opportunity?   @relation(fields: [opportunityId], references: [id], onDelete: SetNull)

  ownerId            String?
  owner              User?          @relation("ContractOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  previousContractId String?        @unique
  previousContract   Contract?      @relation("ContractRenewal", fields: [previousContractId], references: [id], onDelete: SetNull)
  nextContract       Contract?      @relation("ContractRenewal")

  // Synchronisation outil de facturation externe
  // @deprecated 2026-05 : Sellsy retire du stack MDO. Champ conserve pour
  // ne pas perdre les references historiques d'abonnements deja synchronises.
  sellsySubscriptionId String?      @unique
  externalSyncedAt   DateTime?

  description        String?

  alerts             ContractRenewalAlert[]
  tasks              Task[]
  notesRel           Note[]
  interventions      Intervention[]
  tickets            Ticket[]
  timeEntries        TimeEntry[]
  assets             Asset[]
  invoices           Invoice[]
  recurringTemplates RecurringTaskTemplate[]
  // Quote dont la conversion a cree ce contrat (1-1, optional). Nomme via la
  // relation "ContractFromQuote" pour eviter le conflit avec d'autres relations
  // potentielles avec Quote a l'avenir.
  fromQuote          Quote?         @relation("ContractFromQuote")

  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([companyId])
  @@index([ownerId])
  @@index([status])
  @@index([endDate])
  // Compositie pour le cron renewal-alerts (filtre status=ACTIVE + endDate BETWEEN now AND now+90d)
  // et pour stats() dashboard. Reduit le bookmark lookup quand on a >1000 contrats.
  @@index([status, endDate])
}

model ContractRenewalAlert {
  id          String    @id @default(uuid())
  contractId  String
  contract    Contract  @relation(fields: [contractId], references: [id], onDelete: Cascade)
  daysBefore  Int
  alertDate   DateTime
  sentAt      DateTime?
  resolved    Boolean   @default(false)
  createdAt   DateTime  @default(now())

  @@index([contractId])
  @@index([alertDate, sentAt])
}

// =================== INTERVENTIONS ===================

enum InterventionType {
  ONSITE
  REMOTE
  PHONE
}

enum InterventionStatus {
  PLANNED
  IN_PROGRESS
  DONE
  CANCELLED
}

model Intervention {
  id           String             @id @default(uuid())
  title        String
  type         InterventionType   @default(REMOTE)
  status       InterventionStatus @default(PLANNED)
  scheduledAt  DateTime
  startedAt    DateTime?
  endedAt      DateTime?
  durationMin  Int?
  description  String?
  report       String?

  companyId    String
  company      Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)

  contractId   String?
  contract     Contract?          @relation(fields: [contractId], references: [id], onDelete: SetNull)

  ticketId     String?
  ticket       Ticket?            @relation(fields: [ticketId], references: [id], onDelete: SetNull)

  technicianId String?
  technician   User?              @relation("InterventionTechnician", fields: [technicianId], references: [id], onDelete: SetNull)

  timeEntries  TimeEntry[]

  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([companyId])
  @@index([contractId])
  @@index([technicianId])
  @@index([scheduledAt])
}

// =================== TASKS / NOTES / ACTIVITY ===================

enum TaskPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum TaskStatus {
  TODO
  DOING
  DONE
  CANCELLED
}

model Task {
  id            String       @id @default(uuid())
  title         String
  description   String?
  priority      TaskPriority @default(NORMAL)
  status        TaskStatus   @default(TODO)
  dueDate       DateTime?
  completedAt   DateTime?

  createdById   String
  createdBy     User         @relation("TaskCreator", fields: [createdById], references: [id], onDelete: Restrict)
  assigneeId    String?
  assignee      User?        @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  companyId     String?
  company       Company?     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contactId     String?
  contact       Contact?     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  opportunityId String?
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  contractId    String?
  contract      Contract?    @relation(fields: [contractId], references: [id], onDelete: Cascade)

  // Trace de l'origine recurrente : si cette Task a ete generee automatiquement
  // par un RecurringTaskTemplate, on garde la reference pour pouvoir afficher
  // "Tache generee depuis le modele 'Check backup mensuel'" + permettre la
  // suppression en cascade quand on supprime le modele.
  recurringTemplateId String?
  recurringTemplate   RecurringTaskTemplate? @relation(fields: [recurringTemplateId], references: [id], onDelete: SetNull)

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([assigneeId])
  @@index([status])
  @@index([dueDate])
  // Composite kanban : SELECT WHERE status=X ORDER BY dueDate (page tasks).
  @@index([status, dueDate])
  // FKs souvent filtrees mais sans index dedie (cascade depuis Company/Contact/...).
  @@index([companyId])
  @@index([contractId])
  @@index([recurringTemplateId])
}

// =================== RECURRING TASK TEMPLATES ===================
//
// Modeles de taches recurrentes auto-generees par cron : "Check backup mensuel
// client X", "Revue trimestriel client Y", "Patch management mensuel global", etc.
// Le cron tourne une fois par jour ; pour chaque template dont nextRunAt <= now,
// il cree une Task et recalcule nextRunAt selon la frequence.
//
// Scope : si companyId est defini, la Task generee sera rattachee a cette societe.
// Sinon (template global) la Task est cree sans rattachement direct mais reste
// visible dans /tasks pour l'assignee.

enum RecurringFrequency {
  WEEKLY      // tous les 7 jours
  MONTHLY     // tous les mois (au dayOfMonth si defini, sinon meme date que startsOn)
  QUARTERLY   // tous les 3 mois
  YEARLY      // tous les ans
}

model RecurringTaskTemplate {
  id              String              @id @default(uuid())
  name            String              // libelle modele ("Check backup mensuel")
  // Champs reproduits sur chaque Task generee :
  title           String              // titre de la Task (peut contenir le mois pour mensuel)
  description     String?
  priority        TaskPriority        @default(NORMAL)
  // Generation : on cree la Task a la prochaine date prevue (nextRunAt), avec
  // dueDate = generatedAt + dueDateOffsetDays. Permet "Generee le 1er du mois,
  // a faire pour le 15".
  dueDateOffsetDays Int               @default(7)
  frequency       RecurringFrequency  @default(MONTHLY)
  // Jour du mois pour MONTHLY/QUARTERLY/YEARLY (1-28 pour eviter les soucis de
  // fevrier). Null = on prend le jour du startsOn comme reference.
  dayOfMonth      Int?
  // Date de demarrage et arret optionnel
  startsOn        DateTime            @default(now())
  endsOn          DateTime?
  // Prochain horodatage attendu de generation (recalcule apres chaque run).
  nextRunAt       DateTime
  lastRunAt       DateTime?
  // Compteur d'instances generees (info admin, pas critique)
  generatedCount  Int                 @default(0)
  isActive        Boolean             @default(true)
  // Rattachements optionnels appliques aux Tasks generees
  companyId       String?
  company         Company?            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  assigneeId      String?
  assignee        User?               @relation("RecurringTemplateAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  contractId      String?
  contract        Contract?           @relation(fields: [contractId], references: [id], onDelete: SetNull)
  // Audit
  createdById     String
  createdBy       User                @relation("RecurringTemplateCreator", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  tasks           Task[]

  @@index([nextRunAt, isActive])
  @@index([companyId])
}

model Note {
  id            String       @id @default(uuid())
  content       String
  authorId      String
  author        User         @relation(fields: [authorId], references: [id], onDelete: Restrict)

  companyId     String?
  company       Company?     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contactId     String?
  contact       Contact?     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  opportunityId String?
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  contractId    String?
  contract      Contract?    @relation(fields: [contractId], references: [id], onDelete: Cascade)

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([authorId])
  @@index([companyId])
}

model Activity {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action     String
  entity     String
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
}

// =================== EMAILS ===================

model EmailTemplate {
  id         String   @id @default(uuid())
  key        String   @unique
  name       String
  subject    String
  bodyHtml   String
  bodyText   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

enum EmailStatus {
  QUEUED
  SENT
  FAILED
}

model Setting {
  key         String   @id
  value       String?
  isSecret    Boolean  @default(false)
  category    String   @default("general")
  label       String?
  description String?
  updatedAt   DateTime @default(now()) @updatedAt
  updatedById String?

  @@index([category])
}

model EmailLog {
  id              String      @id @default(uuid())
  toEmail         String
  subject         String
  bodyHtml        String
  status          EmailStatus @default(QUEUED)
  error           String?
  relatedEntity   String?
  relatedEntityId String?
  sentAt          DateTime?
  createdAt       DateTime    @default(now())

  @@index([status])
  @@index([toEmail])
  // Permet de retrouver rapidement tous les emails lies a une entite donnee
  // (contrat, ticket, societe...) pour l'historique des relations.
  @@index([relatedEntity, relatedEntityId])
}

// =================== TICKETS (support client) ===================

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_CUSTOMER
  RESOLVED
  CLOSED
  CANCELLED
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum TicketCategory {
  INCIDENT
  REQUEST
  QUESTION
  BUG
  OTHER
}

enum TicketChannel {
  PORTAL
  EMAIL
  PHONE
  ONSITE
  INTERNAL
}

model Ticket {
  id              String         @id @default(uuid())
  reference       String         @unique
  title           String
  description     String
  status          TicketStatus   @default(OPEN)
  priority        TicketPriority @default(NORMAL)
  category        TicketCategory @default(INCIDENT)
  channel         TicketChannel  @default(INTERNAL)

  firstResponseAt DateTime?
  resolvedAt      DateTime?
  closedAt        DateTime?
  dueDate         DateTime?

  companyId       String
  company         Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)

  contactId       String?
  contact         Contact?       @relation(fields: [contactId], references: [id], onDelete: SetNull)

  contractId      String?
  contract        Contract?      @relation(fields: [contractId], references: [id], onDelete: SetNull)

  assigneeId      String?
  assignee        User?          @relation("TicketAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  createdById     String
  createdBy       User           @relation("TicketCreator", fields: [createdById], references: [id], onDelete: Restrict)

  messages        TicketMessage[]
  interventions   Intervention[]
  attachments     Attachment[]
  timeEntries     TimeEntry[]
  satisfaction    TicketSatisfaction?

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([companyId])
  @@index([assigneeId])
  @@index([status])
  @@index([priority])
  @@index([reference])
  // Composite pour le kanban (ORDER BY priority DESC, createdAt DESC) et le
  // filtre commun status+priority des dashboards techniciens.
  @@index([status, priority])
  // Composite pour le compteur "overdue" : status IN (...) AND dueDate < NOW.
  @@index([status, dueDate])
}

model TicketMessage {
  id          String   @id @default(uuid())
  ticketId    String
  ticket      Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId    String?
  author      User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  authorName  String?
  authorEmail String?
  content     String
  isInternal  Boolean  @default(false)
  // Email threading
  messageId   String?  @unique  // Message-ID pour les emails (entrants ou sortants)
  inReplyTo   String?  // In-Reply-To header (chaining)
  viaEmail    Boolean  @default(false)  // true si message issu d'un email
  // CC / BCC (texte simple separe par virgules)
  cc          String?
  bcc         String?
  attachments Attachment[]
  createdAt   DateTime @default(now())

  @@index([ticketId])
  @@index([inReplyTo])
}

// =================== ATTACHMENTS ===================

model Attachment {
  id           String         @id @default(uuid())
  filename     String         // nom de fichier original cote client
  storageKey   String         @unique // chemin / UUID de stockage sur disque
  mimeType     String
  sizeBytes    Int

  uploadedById String?
  uploadedBy   User?          @relation("AttachmentUploader", fields: [uploadedById], references: [id], onDelete: SetNull)

  // Liens polymorphes : un attachment peut etre attache a un ticket directement
  // ou a un message specifique du ticket
  ticketId     String?
  ticket       Ticket?        @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  ticketMessageId String?
  ticketMessage   TicketMessage? @relation(fields: [ticketMessageId], references: [id], onDelete: Cascade)

  createdAt    DateTime       @default(now())

  @@index([ticketId])
  @@index([ticketMessageId])
}

// =================== TIME TRACKING ===================

model TimeEntry {
  id            String        @id @default(uuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  startedAt     DateTime
  endedAt       DateTime?
  durationMin   Int?
  description   String?
  billable      Boolean       @default(true)
  // Taux horaire applique (HT). Optionnel : si null au moment de la facturation,
  // on retombe sur le taux defini au niveau du contrat ou un defaut global.
  hourlyRateHt  Decimal?      @db.Decimal(10, 2)

  // Rattachement client : direct (saisie libre depuis /time) ou implicite via
  // ticket/intervention/contract. Le service de facturation agregera en
  // priorite par companyId, sinon par companyId du ticket/intervention/contract.
  companyId      String?
  company        Company?      @relation(fields: [companyId], references: [id], onDelete: SetNull)
  ticketId       String?
  ticket         Ticket?       @relation(fields: [ticketId], references: [id], onDelete: SetNull)
  interventionId String?
  intervention   Intervention? @relation(fields: [interventionId], references: [id], onDelete: SetNull)
  contractId     String?
  contract       Contract?     @relation(fields: [contractId], references: [id], onDelete: SetNull)

  // Suivi de la facturation : quand l'entree a-t-elle ete poussee dans Sellsy/
  // Qonto ? `invoiceReference` peut etre l'ID Sellsy de la facture brouillon,
  // un n. de facture, ou un libre texte. Permet le filtre "non facturees" pour
  // la page admin de billing.
  invoicedAt        DateTime?
  invoiceReference  String?
  invoicedById      String?
  invoicedBy        User?     @relation("TimeEntryInvoicer", fields: [invoicedById], references: [id], onDelete: SetNull)

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([userId, startedAt])
  @@index([ticketId])
  @@index([interventionId])
  @@index([contractId])
  @@index([companyId, invoicedAt])
  @@index([invoicedAt])
}

// =================== NOTIFICATIONS IN-APP ===================

enum NotificationType {
  TICKET_ASSIGNED
  TICKET_NEW_MESSAGE
  TICKET_OVERDUE
  CONTRACT_EXPIRING
  TASK_ASSIGNED
  INTERVENTION_REMINDER
  GENERIC
}

model Notification {
  id         String           @id @default(uuid())
  userId     String
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       NotificationType @default(GENERIC)
  title      String
  body       String?
  entity     String?
  entityId   String?
  url        String?
  readAt     DateTime?
  createdAt  DateTime         @default(now())

  @@index([userId, readAt])
  @@index([createdAt])
}

// =================== RESPONSE TEMPLATES ===================

model ResponseTemplate {
  id        String   @id @default(uuid())
  name      String
  category  String?
  subject   String?
  body      String
  ownerId   String?  // null = partage avec tous
  owner     User?    @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
}

// =================== ASSETS (materiel / licences clients) ===================

enum AssetType {
  HARDWARE
  LICENSE
  SOFTWARE
  DOMAIN
  CERTIFICATE
  M365_LICENSE
  OTHER
}

enum AssetStatus {
  ACTIVE
  INACTIVE
  EXPIRED
  RETIRED
}

model Asset {
  id             String        @id @default(uuid())
  name           String
  type           AssetType     @default(HARDWARE)
  status         AssetStatus   @default(ACTIVE)
  identifier     String?       // numero de serie, cle de licence, FQDN, etc.
  vendor         String?       // Microsoft, HP, Lenovo, etc.
  model          String?
  acquiredAt     DateTime?
  warrantyUntil  DateTime?
  expiresAt      DateTime?     // pour licences/domains/certs
  costHt         Decimal?      @db.Decimal(10, 2)
  notes          String?
  // Auto-monitoring SSL / WHOIS (DOMAIN, CERTIFICATE)
  // expiresAt est rempli automatiquement, lastMonitoredAt = horodatage du dernier check.
  // monitoringEnabled = false desactive le cron pour cet asset.
  lastMonitoredAt DateTime?
  monitoringEnabled Boolean   @default(true)
  monitoringError String?    // dernier message d'erreur si check echoue

  companyId      String
  company        Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contractId     String?
  contract       Contract?     @relation(fields: [contractId], references: [id], onDelete: SetNull)

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([companyId])
  @@index([contractId])
  @@index([type])
  @@index([expiresAt])
}

// =================== UPTIME MONITORING ===================

// Surveillance HTTP/HTTPS d'un site ou endpoint client. Le cron uptime
// frappe l'URL toutes les `intervalMinutes` minutes et stocke un check
// dans UptimeCheck. Apres N echecs consecutifs, un UptimeIncident est
// ouvert + notification (in-app + email) au proprietaire.
model UptimeMonitor {
  id              String           @id @default(uuid())
  name            String           // libelle ("Site vitrine ACME")
  url             String           // ex: https://www.acme.fr/
  method          String           @default("GET")
  expectedStatus  Int              @default(200)
  intervalMinutes Int              @default(5)
  enabled         Boolean          @default(true)
  // Expose ce monitor sur la page /status publique (anonymisee, sans URL ni nom client).
  // Defaut false : tous les monitors clients sont prives. A activer manuellement pour
  // les services internes MDO (CRM, site vitrine, etc.) qu'on veut montrer publiquement.
  isPublic        Boolean          @default(false)

  companyId       String?
  company         Company?         @relation(fields: [companyId], references: [id], onDelete: SetNull)

  // Cache du dernier etat pour les listings rapides
  lastCheckedAt   DateTime?
  lastStatus      String?          // "UP" | "DOWN" | null
  lastHttpCode    Int?
  lastResponseMs  Int?
  lastError       String?
  consecutiveFailures Int          @default(0)
  alertSentAt     DateTime?        // pour eviter spam

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  checks          UptimeCheck[]
  incidents       UptimeIncident[]

  @@index([companyId])
  @@index([enabled])
}

model UptimeCheck {
  id          String         @id @default(uuid())
  monitorId   String
  monitor     UptimeMonitor  @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  checkedAt   DateTime       @default(now())
  isUp        Boolean
  httpCode    Int?
  responseMs  Int?
  error       String?

  @@index([monitorId, checkedAt])
}

model UptimeIncident {
  id              String         @id @default(uuid())
  monitorId       String
  monitor         UptimeMonitor  @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  startedAt       DateTime
  endedAt         DateTime?
  durationSeconds Int?
  reason          String?        // dernier message d'erreur observe

  @@index([monitorId, startedAt])
}

// =================== DOCUMENTATION CLIENT (KB) ===================

model DocPage {
  id          String   @id @default(uuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  title       String
  category    String?  // ex: Reseau, Acces, Procedures, Onboarding
  body        String   // markdown
  authorId    String?
  author      User?    @relation("DocPageAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  versions    DocPageVersion[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyId])
  @@index([category])
}

// Snapshot d'une page de doc avant chaque modification.
// Cree automatiquement au moment du PATCH pour permettre rollback.
model DocPageVersion {
  id          String   @id @default(uuid())
  pageId      String
  page        DocPage  @relation(fields: [pageId], references: [id], onDelete: Cascade)
  title       String
  category    String?
  body        String
  authorId    String?  // qui a fait la modif qui a cree cette version (= valeur AVANT modif)
  reason      String?  // commentaire optionnel ("avant refonte reseau")
  createdAt   DateTime @default(now())

  @@index([pageId, createdAt])
}

// Coffre-fort de secrets cote client (mots de passe, cles d'acces).
// La valeur est stockee chiffree avec une cle maitre derive de SECRETS_MASTER_KEY.
model SecretEntry {
  id          String   @id @default(uuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  label       String   // "Acces admin firewall", "Compte M365 admin", etc.
  username    String?
  // Les champs ciphered* contiennent { iv, authTag, data } encodes en base64
  cipheredValue String  // mot de passe / cle chiffre
  // Secret TOTP (base32) chiffre, pour generer les codes 2FA partages
  // (compte admin firewall, M365 break-glass, etc.). Optionnel.
  cipheredTotp  String?
  url         String?
  category    String?
  notes       String?
  createdById String?
  createdBy   User?    @relation("SecretEntryCreator", fields: [createdById], references: [id], onDelete: SetNull)
  lastAccessedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyId])
}

// =================== FACTURATION ===================

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  OVERDUE
  CANCELLED
}

// Origine de la facture : interne au CRM, ou miroir d'un outil externe (PDP)
enum BillingProviderKind {
  INTERNAL  // Facture generee dans le CRM (mode legacy / compatibilite)
  // @deprecated 2026-05 : Sellsy retire du stack MDO. Valeur conservee pour
  // preserver l'integrite des Invoice historiques deja crees avec ce provider.
  SELLSY
  QONTO     // Source de verite : Qonto Factures (PDP)
}

model Invoice {
  id             String        @id @default(uuid())
  number         String        @unique  // ex : 2026-04-0001
  status         InvoiceStatus @default(DRAFT)
  issueDate      DateTime      @default(now())
  dueDate        DateTime
  paidAt         DateTime?
  totalHt        Decimal       @db.Decimal(12, 2)
  totalTtc       Decimal       @db.Decimal(12, 2)
  vatRate        Decimal       @default(20) @db.Decimal(5, 2)
  notes          String?

  // Source / synchronisation avec un outil de facturation externe
  provider         BillingProviderKind @default(INTERNAL)
  externalId       String?      // ID dans Sellsy / Qonto
  externalUrl      String?      // URL profonde vers la facture dans l'outil source
  externalPdfUrl   String?      // URL PDF directe (si disponible)
  externalSyncedAt DateTime?

  companyId      String
  company        Company       @relation(fields: [companyId], references: [id], onDelete: Restrict)
  contractId     String?
  contract       Contract?     @relation(fields: [contractId], references: [id], onDelete: SetNull)

  lines          InvoiceLine[]
  bankTransactions BankTransaction[]

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([provider, externalId])
  @@index([companyId])
  @@index([contractId])
  @@index([status])
  @@index([issueDate])
  @@index([provider])
}

model InvoiceLine {
  id          String   @id @default(uuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  quantity    Decimal  @db.Decimal(10, 2)
  unitPriceHt Decimal  @db.Decimal(10, 2)
  totalHt     Decimal  @db.Decimal(12, 2)

  @@index([invoiceId])
}

// =================== TRESORERIE / BANQUE (Qonto) ===================

enum BankSource {
  QONTO
  MANUAL
  OTHER
}

enum BankTransactionSide {
  CREDIT
  DEBIT
}

// Mouvements bancaires importes depuis Qonto, conserves en cache pour
// rapprochement avec les factures (par client) et vue tresorerie.
model BankTransaction {
  id             String              @id @default(uuid())
  source         BankSource          @default(QONTO)
  externalId     String              @unique  // qonto transaction id
  bookedAt       DateTime
  side           BankTransactionSide
  amount         Decimal             @db.Decimal(14, 2)  // montant absolu
  currency       String              @default("EUR")
  label          String              // libelle nettoye
  rawLabel       String?             // libelle brut (debug)
  counterparty   String?             // nom IBAN/contrepartie
  reference      String?             // reference virement
  status         String?             // completed / pending (Qonto)

  companyId      String?             // rapproche a un client
  company        Company?            @relation(fields: [companyId], references: [id], onDelete: SetNull)
  invoiceId      String?             // rapproche a une facture
  invoice        Invoice?            @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  importedAt     DateTime            @default(now())

  @@index([bookedAt])
  @@index([companyId])
  @@index([invoiceId])
  @@index([status])
}

// =================== DOCUMENTATION CLIENT - IT GLUE LIKE ===================

// Sites physiques d'un client (multi-site).
// Permet de localiser materiel, contacts, interventions par site.
model Location {
  id          String   @id @default(uuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name        String   // ex : "Siege Toulouse", "Agence Montpellier"
  isPrimary   Boolean  @default(false)
  address     String?
  postalCode  String?
  city        String?
  country     String?  @default("France")
  phone       String?
  notes       String?
  // Coordonnees GPS pour cartographie / planning intervention
  latitude    Float?
  longitude   Float?

  networks    Network[]
  flexibleAssets FlexibleAsset[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyId])
}

enum NetworkKind {
  LAN
  WAN
  WIFI
  VPN
  DMZ
  GUEST
  OTHER
}

// Reseaux d'un client : plages IP, VLANs, sous-reseaux, gateway, DNS.
// Sert de doc reseau structuree (au lieu de markdown a la main).
model Network {
  id          String      @id @default(uuid())
  companyId   String
  company     Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  locationId  String?
  location    Location?   @relation(fields: [locationId], references: [id], onDelete: SetNull)

  name        String      // "LAN bureaux", "WIFI guest", "VPN site to site"
  kind        NetworkKind @default(LAN)
  cidr        String?     // ex : "10.0.0.0/24"
  vlanId      Int?
  gateway     String?
  dnsServers  String?     // separes par virgule
  dhcpStart   String?
  dhcpEnd     String?
  description String?

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([companyId])
  @@index([locationId])
}

// ----- Flexible Assets (cle de voute IT Glue-like) -----
// Permet de definir des templates de documentation custom par MSP :
// "Tenant M365", "Firewall Fortinet", "Backup Veeam", "ISP", "AD config", etc.
// Chaque template definit un schema de champs, et chaque instance stocke les valeurs.

enum FlexibleFieldType {
  TEXT
  TEXTAREA
  NUMBER
  BOOLEAN
  DATE
  URL
  EMAIL
  PASSWORD       // valeur stockee chiffree dans FlexibleAsset.secretValues
  IP_ADDRESS
  SELECT
  MULTISELECT
  REFERENCE_COMPANY
  REFERENCE_CONTACT
  REFERENCE_ASSET
}

// Definition d'un type d'asset flexible (template).
// Cree par l'admin, reutilise sur tous les clients.
model FlexibleAssetType {
  id          String   @id @default(uuid())
  name        String   @unique
  icon        String?  // nom Lucide icon (ex: "Server", "Cloud", "Shield")
  color       String?  // couleur hex pour affichage
  description String?
  fields      FlexibleAssetField[]
  assets      FlexibleAsset[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Definition d'un champ d'un type flexible.
model FlexibleAssetField {
  id           String              @id @default(uuid())
  typeId       String
  type         FlexibleAssetType   @relation(fields: [typeId], references: [id], onDelete: Cascade)
  key          String              // ex : "tenant_id", "contract_end"
  label        String              // ex : "Identifiant tenant"
  fieldType    FlexibleFieldType   @default(TEXT)
  required     Boolean             @default(false)
  position     Int                 @default(0)
  // Pour SELECT / MULTISELECT : options separees par "|"
  options      String?
  // Pour les references : on stocke "Company" / "Contact" / "Asset" ici si besoin
  refEntity    String?
  // Aide affichee dans le formulaire
  helpText     String?

  @@unique([typeId, key])
  @@index([typeId])
}

// Instance d'un type flexible pour un client donne.
// Les valeurs des champs sont stockees en JSON ; les champs PASSWORD
// dans secretValues (cipheredValues separes par cle).
model FlexibleAsset {
  id          String              @id @default(uuid())
  typeId      String
  type        FlexibleAssetType   @relation(fields: [typeId], references: [id], onDelete: Restrict)
  companyId   String
  company     Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  locationId  String?
  location    Location?           @relation(fields: [locationId], references: [id], onDelete: SetNull)

  name        String              // libelle de l'instance, ex : "Tenant M365 prod"
  // Valeurs en clair (texte/nombre/date/bool/etc.) ; key = field.key
  values      Json                @default("{}")
  // Valeurs chiffrees (champs PASSWORD) ; key = field.key, value = base64 cipher
  secretValues Json               @default("{}")

  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([companyId])
  @@index([typeId])
  @@index([locationId])
}

// Quick Notes : post-it epingles par societe pour les infos critiques rapides.
// "Acces VPN -> exception sur l'IP X.X.X.X", "Contact urgence : 06...", etc.
model QuickNote {
  id          String   @id @default(uuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  content     String
  color       String?  // jaune, rouge, vert (couleur post-it)
  pinned      Boolean  @default(true)
  authorId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyId])
}

// =================== RUNBOOKS / PROCEDURES ===================

enum RunbookCategory {
  ONBOARDING
  AUDIT
  PATCHING
  INCIDENT
  OFFBOARDING
  AUTRE
}

// Modele de procedure reutilisable (catalogue partage entre tous les clients).
// Ex : "Onboarding nouveau client", "Audit trimestriel", "Patch management mensuel".
model Runbook {
  id          String           @id @default(uuid())
  name        String
  category    RunbookCategory  @default(AUTRE)
  description String?
  steps       RunbookStep[]
  runs        RunbookRun[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

// Etape d'un runbook template.
model RunbookStep {
  id           String   @id @default(uuid())
  runbookId    String
  runbook      Runbook  @relation(fields: [runbookId], references: [id], onDelete: Cascade)
  position     Int      @default(0)
  title        String
  details      String?  // markdown : explication, lien, snippet, etc.
  estimatedMin Int?     // duree estimee en minutes
  required     Boolean  @default(true)

  @@index([runbookId, position])
}

// Instance executee d'un runbook pour un client donne.
// Conserve la check-list cochee + qui a fait quoi quand.
model RunbookRun {
  id           String   @id @default(uuid())
  runbookId    String
  runbook      Runbook  @relation(fields: [runbookId], references: [id], onDelete: Restrict)
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  startedById  String?
  startedAt    DateTime @default(now())
  completedAt  DateTime?
  // Etat des cases : { stepId: { done: bool, doneById: string, doneAt: iso, note: string } }
  state        Json     @default("{}")

  @@index([companyId])
  @@index([runbookId])
}

// Relation polymorphe entre items du CRM (Asset, FlexibleAsset, DocPage,
// SecretEntry, Network, Location, Contract, Contact, Ticket, ...).
// Stockes par paire ordonnee (sourceEntity/sourceId, targetEntity/targetId).
model ItemLink {
  id            String   @id @default(uuid())
  sourceEntity  String   // ex : "FlexibleAsset"
  sourceId      String
  targetEntity  String   // ex : "SecretEntry"
  targetId      String
  label         String?  // libelle libre, ex : "credentials admin"
  createdById   String?
  createdAt     DateTime @default(now())

  @@unique([sourceEntity, sourceId, targetEntity, targetId])
  @@index([sourceEntity, sourceId])
  @@index([targetEntity, targetId])
}

// =================== 2FA ===================

model UserMfa {
  userId       String   @id
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  secret       String   // base32 TOTP secret (chiffre avec SECRETS_MASTER_KEY)
  enabled      Boolean  @default(false)
  recoveryCodes String  // JSON liste de codes hashes
  enabledAt    DateTime?
  createdAt    DateTime @default(now())
}

// =================== PORTAIL CLIENT (sous-domaine client.mdoservices.fr) ===================
//
// Authentification distincte des utilisateurs internes (modele User). Un contact
// chez un client peut se connecter via un magic link envoye sur son email pro,
// a condition que le domaine email corresponde a une societe enregistree.
// Acces strictement scope a `companyId` (impossible de voir une autre societe).

model ClientPortalUser {
  id            String   @id @default(uuid())
  email         String   @unique
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  // Lien optionnel vers le Contact CRM correspondant (rempli automatiquement si
  // un Contact existe deja avec cet email pour cette societe).
  contactId     String?
  contact       Contact? @relation("ContactPortalUser", fields: [contactId], references: [id], onDelete: SetNull)
  firstName     String?
  lastName      String?
  isActive      Boolean  @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  magicLinks    ClientPortalMagicLink[]
  sessions      ClientPortalSession[]

  @@index([companyId])
}

model ClientPortalMagicLink {
  id            String   @id @default(uuid())
  userId        String
  user          ClientPortalUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  // On stocke un hash SHA256 du token clair. Le token clair n'apparait que dans
  // l'email envoye au client — une fuite de la BDD ne donne pas acces aux liens.
  tokenHash     String   @unique
  expiresAt     DateTime
  usedAt        DateTime?
  ip            String?
  userAgent     String?
  createdAt     DateTime @default(now())

  @@index([expiresAt])
}

model ClientPortalSession {
  id            String   @id @default(uuid())
  userId        String
  user          ClientPortalUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  token         String   @unique  // opaque, 32 bytes hex
  expiresAt     DateTime
  revokedAt     DateTime?
  ip            String?
  userAgent     String?
  lastUsedAt    DateTime @default(now())
  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

// =================== MICROSOFT 365 / GRAPH API ===================
//
// Pour chaque societe cliente, MDO peut connecter le tenant M365 via OAuth
// admin consent (app multi-tenant enregistree sur le tenant MDO). Une fois
// consenti, MDO peut interroger periodiquement Graph API pour synchroniser
// la liste des utilisateurs, leurs licences, leur statut MFA et les alertes
// de securite.

model M365Tenant {
  id              String   @id @default(uuid())
  companyId       String   @unique
  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  // GUID Entra ID du tenant client (immuable)
  tenantId        String   @unique
  tenantDomain    String?  // ex: acme.onmicrosoft.com
  consentedAt     DateTime?
  consentedBy     String?  // email/nom de l'admin client qui a fait le consent
  lastSyncAt      DateTime?
  lastSyncStatus  String?  // 'OK' | 'FAILED' | 'PARTIAL'
  lastSyncError   String?
  isActive        Boolean  @default(true)
  // Microsoft Secure Score (https://learn.microsoft.com/en-us/graph/api/securescore-get).
  // Indicateur Microsoft officiel de la posture securite du tenant : couvre MFA,
  // conditional access, Defender, partage externe, etc. — beaucoup plus complet
  // que la seule couverture MFA. Necessite la permission SecurityEvents.Read.All
  // ET un tenant avec les licences appropriees (E3/E5/Business Premium). Si non
  // disponible, ces champs restent null et le CRM retombe sur le MFA pur.
  secureScore         Float?    // currentScore brut (echelle Microsoft, generalement 0-1000+)
  secureScoreMax      Float?    // maxScore atteignable pour ce tenant (varie selon licences)
  secureScorePercent  Float?    // currentScore / maxScore * 100 (cache pour filtrer/agreger sans recalculer)
  secureScoreSyncedAt DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  users           M365User[]
  licenses        M365License[]
  alerts          M365SecurityAlert[]

  @@index([companyId])
}

model M365User {
  id             String      @id @default(uuid())
  m365TenantId   String
  m365Tenant     M365Tenant  @relation(fields: [m365TenantId], references: [id], onDelete: Cascade)
  graphId        String      // ID Graph immuable
  upn            String      // user principal name (ex: john@acme.onmicrosoft.com)
  displayName    String?
  jobTitle       String?
  department     String?
  accountEnabled Boolean     @default(true)
  // null = inconnu (API premium non disponible ou pas encore syncho). True/false sinon.
  mfaEnabled     Boolean?
  lastSignInAt   DateTime?
  // skuPartNumbers attribues (ex: ["ENTERPRISEPACK","EMS"])
  licenseSkus    Json
  syncedAt       DateTime    @default(now())

  @@unique([m365TenantId, graphId])
  @@index([m365TenantId])
  @@index([accountEnabled])
  @@index([mfaEnabled])
}

model M365License {
  id              String      @id @default(uuid())
  m365TenantId    String
  m365Tenant      M365Tenant  @relation(fields: [m365TenantId], references: [id], onDelete: Cascade)
  skuId           String      // GUID
  skuPartNumber   String      // ex: ENTERPRISEPACK
  name            String?     // libelle humain (mapping local : ENTERPRISEPACK -> Office 365 E3)
  totalUnits      Int
  consumedUnits   Int
  syncedAt        DateTime    @default(now())

  @@unique([m365TenantId, skuId])
  @@index([m365TenantId])
}

model M365SecurityAlert {
  id              String      @id @default(uuid())
  m365TenantId    String
  m365Tenant      M365Tenant  @relation(fields: [m365TenantId], references: [id], onDelete: Cascade)
  alertId         String      // ID Graph de l'alerte
  severity        String      // low / medium / high / informational
  status          String      // newAlert / inProgress / resolved
  title           String
  description     String?
  category        String?
  createdDateTime DateTime
  syncedAt        DateTime    @default(now())

  @@unique([m365TenantId, alertId])
  @@index([m365TenantId, severity])
  @@index([status])
}

// =================== NPS / SATISFACTION POST-TICKET ===================
//
// Envoi automatique d'un mini-questionnaire au contact du ticket quand le statut
// passe a RESOLVED. Le client clique sur le lien, note de 0 a 10 + commentaire
// optionnel. Stockage dans TicketSatisfaction, agrege ensuite pour le NPS global.

model TicketSatisfaction {
  id              String    @id @default(uuid())
  // Un ticket = au plus une demande NPS active (unique).
  ticketId        String    @unique
  ticket          Ticket    @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  // Token cryptosecure pour la page publique de notation. Indexe pour lookup rapide.
  token           String    @unique
  tokenExpiresAt  DateTime
  sentTo          String
  sentAt          DateTime
  // Reponse du client. Null tant que pas encore soumise.
  score           Int?      // 0 - 10
  comment         String?
  submittedAt     DateTime?
  // IP/UA tronques au moment de la soumission, pour detection de fraude basique.
  submittedIp     String?
  submittedUa     String?

  @@index([sentAt])
  @@index([submittedAt])
  @@index([score])
}

// =================== CLIENT MONTHLY REPORTS ===================
//
// Rapport mensuel par client : agrege tickets resolus, interventions, uptime,
// surveillance certificats/domaines + inventaire assets sur une periode donnee.
// Genere soit manuellement depuis la fiche societe, soit automatiquement le 1er
// de chaque mois via un cron (ClientReportsService.runMonthlyCron).
//
// Le PDF est stocke sur disque (UPLOADS_DIR/client-reports/) et accede via un
// token cryptosecure 32 bytes hex (URL : /api/reports/download/:token). Le
// token a une duree de vie de 30 jours pour ne pas creer de fuites permanentes.

enum ClientReportStatus {
  GENERATED   // PDF cree, pas encore envoye
  SENT        // Email envoye au contact principal
  DOWNLOADED  // Au moins un telechargement effectue via le lien
  EXPIRED     // Token expire (information seulement, le PDF reste accessible en admin)
}

model ClientReport {
  id              String              @id @default(uuid())
  companyId       String
  company         Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  // Periode couverte : mois entier en general (1er → dernier jour).
  periodStart     DateTime
  periodEnd       DateTime
  // Chemin relatif au UPLOADS_DIR (ex. client-reports/2026/05/abcd.pdf)
  pdfPath         String
  // Taille en octets, utile pour les UI et la suppression.
  pdfSize         Int
  // Token cryptosecure pour le download public. Indexe car cle de lookup.
  accessToken     String              @unique
  tokenExpiresAt  DateTime
  status          ClientReportStatus  @default(GENERATED)
  // Stats agregees stockees en JSON pour affichage rapide cote admin sans
  // regenerer le PDF (ex. "12 tickets resolus, 4 interventions, uptime 99.8 %").
  summary         Json
  // Trace de l'envoi
  sentTo          String?
  sentAt          DateTime?
  // Trace des telechargements (count + dernier)
  downloadCount   Int                 @default(0)
  lastDownloadAt  DateTime?
  // Auteur de la generation (null si auto via cron)
  generatedById   String?
  createdAt       DateTime            @default(now())

  @@index([companyId, periodStart])
  @@index([accessToken])
  @@index([tokenExpiresAt])
  @@index([status])
}

// =================== WORKFLOW RULES ENGINE ===================
//
// Moteur de regles simples "quand <trigger> alors <action>". Permet de codifier
// les reflexes operationnels recurrents (alerter sur contrats expirant, creer
// une task sur ticket overdue, etc.) avant l'arrivee d'un collaborateur — qui
// n'aura pas la memoire historique de Mathieu.
//
// Architecture : cron quotidien evalue toutes les regles actives. Pour chaque
// regle, le trigger produit une liste d'entites cible. Pour chaque entite, on
// verifie WorkflowExecution (unique sur ruleId+entityType+entityId) pour
// dedupliquer — une regle ne tire qu'UNE fois par entite, pas une fois par jour.

enum WorkflowTrigger {
  CONTRACT_EXPIRING    // contracts ACTIVE avec endDate dans le futur <= triggerParams.daysBefore
  TICKET_OVERDUE       // tickets non resolus avec dueDate < now
  ASSET_EXPIRING       // assets ACTIVE avec expiresAt dans le futur <= triggerParams.daysBefore
  INVOICE_OVERDUE      // factures non payees avec dueDate < now - triggerParams.daysOverdue
}

enum WorkflowAction {
  CREATE_TASK          // Task creee avec titre/priorite/assignee depuis actionParams
  CREATE_NOTIFICATION  // Notification in-app push vers actionParams.targetRole (ADMIN/MANAGER/OWNER)
}

model WorkflowRule {
  id              String           @id @default(uuid())
  name            String           // libelle admin ("Alerte contrats expirant 60 jours")
  description     String?
  trigger         WorkflowTrigger
  // Parametres du trigger (JSON cle/valeur) :
  //  - CONTRACT_EXPIRING : { daysBefore: number }
  //  - ASSET_EXPIRING : { daysBefore: number }
  //  - INVOICE_OVERDUE : { daysOverdue: number }
  //  - TICKET_OVERDUE : {} (pas de param, dueDate suffit)
  triggerParams   Json             @default("{}")
  action          WorkflowAction
  // Parametres de l'action (JSON cle/valeur) :
  //  - CREATE_TASK : { titleTemplate: string, priority?: TaskPriority,
  //                    dueDateOffsetDays?: number, assigneeId?: string }
  //  - CREATE_NOTIFICATION : { title: string, body?: string,
  //                            targetRole?: 'ADMIN'|'MANAGER'|'OWNER' }
  // titleTemplate supporte des placeholders {entityField} substitues a l'execution
  // (ex. "Preparer renouvellement {reference}" pour CONTRACT_EXPIRING).
  actionParams    Json             @default("{}")
  isActive        Boolean          @default(true)
  // Audit / observabilite
  lastEvaluatedAt DateTime?
  lastFiredAt     DateTime?
  firedCount      Int              @default(0)
  // Assignee par defaut si l'action est CREATE_TASK et qu'aucun assigneeId
  // n'est specifie dans actionParams. Permet de dire "assigne par defaut a moi".
  assigneeId      String?
  assignee        User?            @relation("WorkflowRuleAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  createdById     String
  createdBy       User             @relation("WorkflowRuleCreator", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  executions      WorkflowExecution[]

  @@index([isActive, trigger])
}

model WorkflowExecution {
  id          String        @id @default(uuid())
  ruleId      String
  rule        WorkflowRule  @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  // Identite de l'entite cible (Contract, Ticket, Asset, Invoice). On ne fait
  // PAS de FK Prisma vers chaque type — c'est polymorphe. Si l'entite est
  // supprimee plus tard, l'execution reste pour audit (entityId orphelin = OK).
  entityType  String
  entityId    String
  firedAt     DateTime      @default(now())
  // Resultat textuel pour audit ("TASK_CREATED:<taskId>" ou "NOTIFICATION_SENT:N").
  // Permet de retracer ce que la regle a fait sans charger d'autres tables.
  result      String?

  // Cle de dedup : une regle ne tire qu'UNE fois par entite (sauf reset manuel
  // de l'execution). Si tu veux qu'une regle re-tire periodiquement, supprime
  // l'execution ou ajoute une logique "fireEveryDays" dans triggerParams plus tard.
  @@unique([ruleId, entityType, entityId])
  @@index([firedAt])
  @@index([entityType, entityId])
}

// =================== QUOTES (devis commerciaux) ===================
//
// Etape commerciale entre Opportunity (negociation) et Contract (signe).
// Permet de generer un PDF presentable, de l'envoyer au client, de tracer son
// acceptation puis de le convertir en 1-clic en Contract (toutes les valeurs
// sont reportees, plus le rattachement convertedToContractId).
//
// Workflow : DRAFT -> SENT -> (ACCEPTED|REJECTED|EXPIRED). Un devis ACCEPTED
// peut etre converti en Contract ; apres conversion, status reste ACCEPTED
// (le devis n'est jamais "consume", il reste comme trace commerciale).

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

model Quote {
  id            String      @id @default(uuid())
  reference     String      @unique
  title         String
  status        QuoteStatus @default(DRAFT)
  // Validite : dateLimite d'acceptation cote client. Au-dela, status passe a
  // EXPIRED automatiquement par cron (job journalier dans QuotesService).
  validUntil    DateTime
  issueDate     DateTime    @default(now())
  vatRate       Decimal     @default(20) @db.Decimal(5, 2)
  notes         String?
  // Conditions affichees en bas du PDF (delais paiement, RIB, mentions legales)
  // Editable par devis ; valeur par defaut depuis Settings('quote.defaultTerms').
  terms         String?

  // Totaux denormalises (recalcules a chaque update lignes). Eviter les requetes
  // d'agregation a chaque liste de devis.
  subtotalHt    Decimal     @default(0) @db.Decimal(12, 2)
  vatAmount     Decimal     @default(0) @db.Decimal(12, 2)
  totalTtc      Decimal     @default(0) @db.Decimal(12, 2)

  // Tracage workflow
  sentAt        DateTime?
  acceptedAt    DateTime?
  rejectedAt    DateTime?
  rejectionReason String?

  companyId     String
  company       Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contactId     String?
  contact       Contact?    @relation(fields: [contactId], references: [id], onDelete: SetNull)
  opportunityId String?
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  ownerId       String?
  owner         User?       @relation("QuoteOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  // Si converti en contrat : reference vers le Contract cree. Permet "1 quote
  // -> 1 contract max", on ne peut pas convertir 2 fois le meme devis.
  convertedToContractId String?  @unique
  convertedToContract   Contract? @relation("ContractFromQuote", fields: [convertedToContractId], references: [id], onDelete: SetNull)
  convertedAt           DateTime?

  lines         QuoteLine[]

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([companyId])
  @@index([status])
  @@index([validUntil])
  @@index([status, validUntil])
}

model QuoteLine {
  id          String   @id @default(uuid())
  quoteId     String
  quote       Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  position    Int      @default(0)
  description String
  quantity    Decimal  @default(1) @db.Decimal(10, 2)
  unitPriceHt Decimal  @db.Decimal(10, 2)
  // Remise % appliquee a cette ligne uniquement (0..100). Calcule :
  // lineTotalHt = quantity * unitPriceHt * (1 - discountPct/100).
  discountPct Decimal  @default(0) @db.Decimal(5, 2)
  // Pre-calcule pour la liste des devis et pour le PDF (evite recalcul cote front).
  lineTotalHt Decimal  @db.Decimal(12, 2)

  @@index([quoteId])
}

// =================== SIGNATURE ELECTRONIQUE ===================
//
// Polymorphe : signe un Quote OU un Contract (entityType + entityId, pas de FK
// dure car deux types possibles). Quand le provider notifie via webhook, on
// retrouve le SignatureRequest via providerSubmissionId puis on met a jour
// status + signedAt + on retropropage signedAt sur l'entite cible (Quote.acceptedAt
// si quote, Contract.signedAt si contract).
//
// Providers supportes : DocuSeal (self-hosted, souverain — defaut) et Yousign
// (cloud FR, eIDAS Avance). Selection via Settings('signature.provider').

enum SignatureProvider {
  DOCUSEAL
  YOUSIGN
}

enum SignatureStatus {
  PENDING       // creee, signataire pas encore venu
  VIEWED        // signataire a ouvert le document
  SIGNED        // signature finalisee
  DECLINED      // signataire a refuse
  EXPIRED       // delai de signature depasse
  CANCELLED     // annulee cote MDO avant signature
}

model SignatureRequest {
  id                String            @id @default(uuid())
  // Polymorphe (pas de FK Prisma — l'entite est dereferencable a la main).
  // Utiliser type discriminant ('Quote' | 'Contract') + id pour retrouver l'entite.
  entityType        String            // 'Quote' | 'Contract'
  entityId          String
  provider          SignatureProvider @default(DOCUSEAL)
  status            SignatureStatus   @default(PENDING)

  // Identifiants externes du provider (varient selon le provider) :
  //  - DocuSeal : submission id (numerique, on stocke en string)
  //  - Yousign : signature_request id (UUID)
  providerSubmissionId String?        @unique
  // URL ouvrable par le signataire (envoyee par email)
  providerSignerUrl    String?
  // URL du document signe une fois finalise (CDN provider ou stockage local)
  signedDocumentUrl    String?

  // Signataire principal (un seul pour le MVP — la plupart de nos contrats
  // ont un seul signataire client). Si besoin ulterieur de multi-signataires,
  // ajouter une table SignatureSigner.
  signerName        String
  signerEmail       String
  signerPhone       String?            // pour OTP SMS si provider supporte

  requestedAt       DateTime          @default(now())
  viewedAt          DateTime?
  signedAt          DateTime?
  declinedAt        DateTime?
  declineReason     String?
  expiresAt         DateTime?

  // Audit trail : on garde tous les webhooks recus en JSON pour pouvoir
  // re-jouer / debugger / prouver en cas de litige.
  webhookEvents     Json[]            @default([])

  // Companies/Contact pour faciliter le filtre cote UI (denormalise depuis
  // l'entite cible — petit cout d'ecriture, gros gain en lecture).
  companyId         String?
  company           Company?          @relation(fields: [companyId], references: [id], onDelete: SetNull)

  createdById       String
  createdBy         User              @relation("SignatureRequestCreator", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([entityType, entityId])
  @@index([status])
  @@index([companyId])
}
