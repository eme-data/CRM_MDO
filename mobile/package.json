{
  "name": "crm-mdo-mobile",
  "version": "1.0.0",
  "description": "Wrapper Capacitor mobile (Android + iOS) pour le CRM MDO",
  "private": true,
  "scripts": {
    "init:android": "cap add android",
    "init:ios": "cap add ios",
    "open:android": "cap open android",
    "open:ios": "cap open ios",
    "sync": "cap sync",
    "build:android-debug": "cap sync && cd android && ./gradlew assembleDebug",
    "build:android-release": "cap sync && cd android && ./gradlew assembleRelease"
  },
  "dependencies": {
    "@capacitor/android": "^6.1.2",
    "@capacitor/app": "^6.0.1",
    "@capacitor/browser": "^6.0.3",
    "@capacitor/camera": "^6.1.0",
    "@capacitor/core": "^6.1.2",
    "@capacitor/device": "^6.0.2",
    "@capacitor/ios": "^6.1.2",
    "@capacitor/network": "^6.0.3",
    "@capacitor/push-notifications": "^6.0.4",
    "@capacitor/splash-screen": "^6.0.3",
    "@capacitor/status-bar": "^6.0.2"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.1.2"
  }
}
