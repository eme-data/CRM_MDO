{
    email {$ACME_EMAIL}
}

{$DOMAIN} {
    encode zstd gzip

    # API backend - on conserve le prefixe /api (NestJS a setGlobalPrefix('api'))
    handle /api/* {
        reverse_proxy backend:4000
    }

    # Health check direct (route publique du backend, exclue du globalPrefix)
    handle /health {
        reverse_proxy backend:4000
    }

    # Tout le reste vers le frontend Next.js
    handle {
        reverse_proxy frontend:3000
    }
}
